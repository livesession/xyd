{
  "name": "@apitoolchain/registry-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:tsp": "tsp compile tsp/main.tsp",
    "gen:sql": "sqlc generate",
    "gen": "bun run gen:tsp && bun run gen:sql",
    "migrate": "bun db/migrate.ts",
    "seed": "bun scripts/seed.ts",
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "typecheck": "tsc --noEmit",
    "format": "bunx biome check --write ."
  },
  "dependencies": {
    "@apitoolchain/schemas": "file:../../packages/apitoolchain-schemas",
    "@aws-sdk/client-s3": "^3.700.0",
    "@flystorage/aws-s3": "^1.1.0",
    "@flystorage/file-storage": "^1.1.0",
    "@flystorage/local-fs": "^1.1.0",
    "js-yaml": "^4.1.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@typespec/compiler": "latest",
    "@typespec/http": "latest",
    "@typespec/http-server-js": "latest",
    "typescript": "^5.6.2"
  }
}
