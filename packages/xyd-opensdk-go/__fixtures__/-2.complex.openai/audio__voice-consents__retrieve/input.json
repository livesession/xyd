{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "VoiceConsentResource",
      "kind": "struct",
      "fields": [
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "audio.voice_consent"
          },
          "required": true,
          "description": "The object type, which is always `audio.voice_consent`."
        },
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The consent recording identifier."
        },
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The label provided when the consent recording was uploaded."
        },
        {
          "name": "language",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The BCP 47 language tag for the consent phrase (for example, `en-US`)."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "The Unix timestamp (in seconds) for when the consent recording was created."
        }
      ],
      "description": "A consent recording used to authorize creation of a custom voice."
    }
  ],
  "resources": [
    {
      "name": "audio",
      "resources": [
        {
          "name": "voice-consents",
          "methods": [
            {
              "action": "retrieve",
              "httpMethod": "get",
              "path": "/audio/voice_consents/{consent_id}",
              "operationId": "getVoiceConsent",
              "description": "Retrieve consent recording metadata used for creating custom voices.\n\nSee the [custom voices guide](/docs/guides/text-to-speech#custom-voices). Custom voices are limited to eligible customers.\n",
              "pathParams": [
                {
                  "name": "consent_id",
                  "type": {
                    "kind": "scalar",
                    "scalar": "string"
                  },
                  "required": true,
                  "description": "The ID of the consent recording to retrieve."
                }
              ],
              "responses": [
                {
                  "status": "200",
                  "description": "OK",
                  "contentType": "application/json",
                  "type": {
                    "kind": "ref",
                    "name": "VoiceConsentResource"
                  }
                }
              ],
              "primaryResponse": {
                "kind": "ref",
                "name": "VoiceConsentResource"
              }
            }
          ]
        }
      ]
    }
  ],
