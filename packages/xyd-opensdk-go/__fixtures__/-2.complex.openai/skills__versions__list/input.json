{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "OrderEnum",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "asc"
        },
        {
          "value": "desc"
        }
      ]
    },
    {
      "name": "SkillVersionListResource",
      "kind": "struct",
      "fields": [
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "list"
          },
          "required": true,
          "default": "list",
          "description": "The type of object returned, must be `list`."
        },
        {
          "name": "data",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "SkillVersionResource"
            }
          },
          "required": true,
          "description": "A list of items"
        },
        {
          "name": "first_id",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": true
        },
        {
          "name": "last_id",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": true
        },
        {
          "name": "has_more",
          "type": {
            "kind": "scalar",
            "scalar": "boolean"
          },
          "required": true,
          "description": "Whether there are more items available."
        }
      ]
    },
    {
      "name": "SkillVersionResource",
      "kind": "struct",
      "fields": [
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "skill.version"
          },
          "required": true,
          "default": "skill.version",
          "description": "The object type, which is `skill.version`."
        },
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Unique identifier for the skill version."
        },
        {
          "name": "skill_id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Identifier of the skill for this version."
        },
        {
          "name": "version",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Version number for this skill."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "Unix timestamp (seconds) for when the version was created."
        },
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Name of the skill version."
        },
        {
          "name": "description",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Description of the skill version."
        }
      ]
    }
  ],
  "resources": [
    {
      "name": "skills",
      "resources": [
        {
          "name": "versions",
          "methods": [
            {
              "action": "list",
              "httpMethod": "get",
              "path": "/skills/{skill_id}/versions",
              "operationId": "ListSkillVersions",
              "description": "List skill versions for a skill.",
              "pathParams": [
                {
                  "name": "skill_id",
                  "type": {
                    "kind": "scalar",
                    "scalar": "string"
                  },
                  "required": true,
                  "description": "The identifier of the skill.",
                  "example": "skill_123"
                }
              ],
              "queryParams": [
                {
                  "name": "limit",
                  "type": {
                    "kind": "scalar",
                    "scalar": "integer"
                  },
                  "required": false,
                  "description": "Number of versions to retrieve."
                },
                {
                  "name": "order",
                  "type": {
                    "kind": "ref",
                    "name": "OrderEnum"
                  },
                  "required": false,
                  "description": "Sort order of results by version number."
                },
                {
                  "name": "after",
                  "type": {
                    "kind": "scalar",
                    "scalar": "string"
                  },
                  "required": false,
                  "description": "The skill version ID to start after.",
                  "example": "skillver_123"
                }
              ],
              "responses": [
                {
                  "status": "200",
                  "description": "Success",
                  "contentType": "application/json",
                  "type": {
                    "kind": "ref",
                    "name": "SkillVersionListResource"
                  }
                }
              ],
              "primaryResponse": {
                "kind": "ref",
                "name": "SkillVersionListResource"
              },
              "pagination": {
                "style": "cursor",
                "itemsField": "data",
                "nextField": "has_more",
                "itemType": {
                  "kind": "ref",
                  "name": "SkillVersionResource"
                },
                "cursorParam": "after",
                "limitParam": "limit"
              }
            }
          ]
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
      "maxRetries": 2,
      "retryableStatusCodes": [
        408,
        429,
        500,
        502,
        503,
        504
      ],
      "retryConnectionErrors": true,
      "honorRetryAfterHeader": true,
      "backoff": {
        "initialDelayMs": 500,
        "maxDelayMs": 8000,
        "multiplier": 2,
        "jitter": 0.25
      }
    },
    "timeout": {
      "defaultTimeoutMs": 60000
    },
    "errors": {
      "statusCodeMap": {
        "400": "BadRequest",
        "401": "Unauthorized",
        "403": "PermissionDenied",
        "404": "NotFound",
        "409": "Conflict",
        "422": "UnprocessableEntity",
        "429": "RateLimited"
      },
      "clientErrorKind": "API",
      "serverErrorKind": "Internal"
    },
    "userAgent": {
      "sdkIdentifierTemplate": "{package}-{language}/{version}",
      "includeRuntimeVersion": false,
      "aiAgentEnvVars": {
        "CLAUDE_CODE": "claude-code",
        "CURSOR_AGENT": "cursor",
        "CLINE_ACTIVE": "cline",
        "WINDSURF_ACTIVE": "windsurf",
        "COPILOT_AGENT": "copilot"
      }
    },
    "telemetry": {
      "requestIdHeader": "X-Request-ID",
      "headerName": "X-Client-Telemetry",
      "enabledByDefault": false
    },
    "logging": {
      "events": [
        "request.start",
        "request.success",
        "request.retry",
        "request.rate_limited",
        "request.error",
        "request.connection_error"
      ]
    },
    "idempotency": {
      "headerName": "Idempotency-Key",
      "autoGenerateForPost": true
    },
    "pagination": {
      "autoPageDelayMs": 0
    },
    "requestGuard": {
      "optionKeys": [
        "api_key",
        "apiKey",
        "idempotency_key",
        "idempotencyKey",
        "extra_headers",
        "extraHeaders",
        "max_retries",
        "maxRetries",
        "base_url",
        "baseUrl",
        "timeout"
      ]
    }
  }
}
