          "name": "model",
          "type": {
            "kind": "ref",
            "name": "CreateAssistantRequestModel"
          },
          "required": true,
          "description": "ID of the model to use. You can use the [List models](/docs/api-reference/models/list) API to see all of your available models, or see our [Model overview](/docs/models) for descriptions of them.\n"
        },
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": false
        },
        {
          "name": "description",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": false
        },
        {
          "name": "instructions",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": false
