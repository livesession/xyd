      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "function"
          },
          "required": true,
          "description": "The type of tool being defined: `function`"
        },
        {
          "name": "function",
          "type": {
            "kind": "ref",
            "name": "FunctionObject"
