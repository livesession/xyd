        {
          "name": "tools",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "CreateAssistantRequestToolsItem"
            }
          },
          "required": false,
          "default": [],
          "description": "A list of tool enabled on the assistant. There can be a maximum of 128 tools per assistant. Tools can be of types `code_interpreter`, `file_search`, or `function`.\n"
        },
        {
          "name": "tool_resources",
          "type": {
            "kind": "ref",
            "name": "CreateAssistantRequestToolResources",
            "nullable": true
          },
          "required": false
        },
        {
          "name": "metadata",
          "type": {
            "kind": "ref",
            "name": "Metadata"
          },
          "required": false
        },
        {
          "name": "temperature",
          "type": {
            "kind": "scalar",
            "scalar": "number",
            "nullable": true
          },
          "required": false
        },
        {
          "name": "top_p",
          "type": {
            "kind": "scalar",
            "scalar": "number",
            "nullable": true
          },
          "required": false
        },
        {
          "name": "response_format",
          "type": {
            "kind": "ref",
            "name": "AssistantsApiResponseFormatOption",
            "nullable": true
