{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "VectorStoreFileContentResponse",
      "kind": "struct",
      "fields": [
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "vector_store.file_content.page"
          },
          "required": true,
          "description": "The object type, which is always `vector_store.file_content.page`"
        },
        {
          "name": "data",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "VectorStoreFileContentResponseDataItem"
            }
          },
          "required": true,
          "description": "Parsed content of the file."
        },
        {
          "name": "has_more",
          "type": {
            "kind": "scalar",
            "scalar": "boolean"
          },
          "required": true,
          "description": "Indicates if there are more content pages to fetch."
        },
        {
          "name": "next_page",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": true
        }
      ],
      "description": "Represents the parsed content of a vector store file."
    },
    {
      "name": "VectorStoreFileContentResponseDataItem",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": false,
          "description": "The content type (currently only `\"text\"`)"
        },
        {
          "name": "text",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": false,
          "description": "The text content"
        }
      ]
    }
  ],
  "resources": [
    {
      "name": "vector-stores",
      "resources": [
        {
          "name": "files",
          "methods": [
            {
              "action": "content",
              "httpMethod": "get",
              "path": "/vector_stores/{vector_store_id}/files/{file_id}/content",
              "operationId": "retrieveVectorStoreFileContent",
              "description": "Retrieve the parsed contents of a vector store file.",
              "pathParams": [
                {
                  "name": "vector_store_id",
                  "type": {
                    "kind": "scalar",
                    "scalar": "string"
                  },
                  "required": true,
                  "description": "The ID of the vector store.",
                  "example": "vs_abc123"
                },
                {
                  "name": "file_id",
                  "type": {
                    "kind": "scalar",
                    "scalar": "string"
                  },
                  "required": true,
                  "description": "The ID of the file within the vector store.",
                  "example": "file-abc123"
                }
              ],
              "responses": [
                {
                  "status": "200",
                  "description": "OK",
                  "contentType": "application/json",
                  "type": {
                    "kind": "ref",
                    "name": "VectorStoreFileContentResponse"
                  }
                }
              ],
              "primaryResponse": {
                "kind": "ref",
                "name": "VectorStoreFileContentResponse"
              },
              "pagination": {
                "style": "cursor",
                "itemsField": "data",
                "nextField": "has_more",
                "itemType": {
                  "kind": "ref",
                  "name": "VectorStoreFileContentResponseDataItem"
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
      "maxRetries": 2,
      "retryableStatusCodes": [
        408,
        429,
        500,
        502,
        503,
        504
      ],
      "retryConnectionErrors": true,
      "honorRetryAfterHeader": true,
      "backoff": {
        "initialDelayMs": 500,
        "maxDelayMs": 8000,
        "multiplier": 2,
        "jitter": 0.25
      }
    },
    "timeout": {
      "defaultTimeoutMs": 60000
    },
    "errors": {
      "statusCodeMap": {
        "400": "BadRequest",
        "401": "Unauthorized",
        "403": "PermissionDenied",
        "404": "NotFound",
        "409": "Conflict",
        "422": "UnprocessableEntity",
        "429": "RateLimited"
      },
      "clientErrorKind": "API",
      "serverErrorKind": "Internal"
    },
    "userAgent": {
      "sdkIdentifierTemplate": "{package}-{language}/{version}",
      "includeRuntimeVersion": false,
      "aiAgentEnvVars": {
        "CLAUDE_CODE": "claude-code",
        "CURSOR_AGENT": "cursor",
        "CLINE_ACTIVE": "cline",
        "WINDSURF_ACTIVE": "windsurf",
        "COPILOT_AGENT": "copilot"
      }
    },
    "telemetry": {
      "requestIdHeader": "X-Request-ID",
      "headerName": "X-Client-Telemetry",
      "enabledByDefault": false
    },
    "logging": {
      "events": [
        "request.start",
        "request.success",
        "request.retry",
        "request.rate_limited",
        "request.error",
        "request.connection_error"
      ]
    },
    "idempotency": {
      "headerName": "Idempotency-Key",
      "autoGenerateForPost": true
    },
    "pagination": {
      "autoPageDelayMs": 0
    },
    "requestGuard": {
      "optionKeys": [
        "api_key",
        "apiKey",
        "idempotency_key",
        "idempotencyKey",
        "extra_headers",
        "extraHeaders",
        "max_retries",
        "maxRetries",
        "base_url",
        "baseUrl",
        "timeout"
      ]
    }
  }
}
