{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "CompleteUploadRequest",
      "kind": "struct",
      "fields": [
        {
          "name": "part_ids",
          "type": {
            "kind": "array",
            "items": {
              "kind": "scalar",
              "scalar": "string"
            }
          },
          "required": true,
          "description": "The ordered list of Part IDs.\n"
        },
        {
          "name": "md5",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": false,
          "description": "The optional md5 checksum for the file contents to verify if the bytes uploaded matches what you expect.\n"
        }
      ]
    },
    {
      "name": "Upload",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The Upload unique identifier, which can be referenced in API endpoints."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "The Unix timestamp (in seconds) for when the Upload was created."
        },
        {
          "name": "filename",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The name of the file to be uploaded."
        },
        {
          "name": "bytes",
          "type": {
            "kind": "scalar",
            "scalar": "integer"
          },
          "required": true,
          "description": "The intended number of bytes to be uploaded."
        },
        {
          "name": "purpose",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The intended purpose of the file. [Please refer here](/docs/api-reference/files/object#files/object-purpose) for acceptable values."
        },
        {
          "name": "status",
          "type": {
            "kind": "ref",
            "name": "UploadStatus"
          },
          "required": true,
          "description": "The status of the Upload."
        },
        {
          "name": "expires_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "The Unix timestamp (in seconds) for when the Upload will expire."
        },
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "upload"
          },
          "required": false,
          "description": "The object type, which is always \"upload\"."
        },
        {
          "name": "file",
          "type": {
            "kind": "ref",
            "name": "OpenAiFile",
            "nullable": true
          },
          "required": false
        }
      ],
      "description": "The Upload object can accept byte chunks in the form of Parts.\n"
    },
    {
      "name": "UploadStatus",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "pending"
        },
        {
          "value": "completed"
        },
        {
          "value": "cancelled"
        },
        {
          "value": "expired"
        }
      ],
      "description": "The status of the Upload."
    },
    {
      "name": "OpenAiFile",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The file identifier, which can be referenced in the API endpoints."
        },
        {
          "name": "bytes",
          "type": {
            "kind": "scalar",
            "scalar": "integer"
          },
          "required": true,
          "description": "The size of the file, in bytes."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "The Unix timestamp (in seconds) for when the file was created."
        },
        {
          "name": "expires_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": false,
          "description": "The Unix timestamp (in seconds) for when the file will expire."
        },
        {
          "name": "filename",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The name of the file."
        },
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "file"
          },
          "required": true,
          "description": "The object type, which is always `file`."
        },
        {
          "name": "purpose",
          "type": {
            "kind": "ref",
            "name": "OpenAiFilePurpose"
          },
          "required": true,
          "description": "The intended purpose of the file. Supported values are `assistants`, `assistants_output`, `batch`, `batch_output`, `fine-tune`, `fine-tune-results`, `vision`, and `user_data`."
        },
        {
          "name": "status",
          "type": {
            "kind": "ref",
            "name": "OpenAiFileStatus"
          },
          "required": true,
          "deprecated": true,
          "description": "Deprecated. The current status of the file, which can be either `uploaded`, `processed`, or `error`."
        },
        {
          "name": "status_details",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": false,
          "deprecated": true,
          "description": "Deprecated. For details on why a fine-tuning training file failed validation, see the `error` field on `fine_tuning.job`."
        }
      ],
      "description": "The `File` object represents a document that has been uploaded to OpenAI."
    },
    {
      "name": "OpenAiFilePurpose",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "assistants"
        },
        {
          "value": "assistants_output"
        },
        {
          "value": "batch"
        },
        {
          "value": "batch_output"
        },
        {
          "value": "fine-tune"
        },
        {
          "value": "fine-tune-results"
        },
        {
          "value": "vision"
        },
        {
          "value": "user_data"
        }
      ],
      "description": "The intended purpose of the file. Supported values are `assistants`, `assistants_output`, `batch`, `batch_output`, `fine-tune`, `fine-tune-results`, `vision`, and `user_data`."
    },
    {
      "name": "OpenAiFileStatus",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "uploaded"
        },
        {
          "value": "processed"
        },
        {
          "value": "error"
        }
      ],
      "description": "Deprecated. The current status of the file, which can be either `uploaded`, `processed`, or `error`."
    }
  ],
  "resources": [
    {
      "name": "uploads",
      "methods": [
        {
          "action": "complete",
          "httpMethod": "post",
          "path": "/uploads/{upload_id}/complete",
          "operationId": "completeUpload",
          "description": "Completes the [Upload](/docs/api-reference/uploads/object). \n\nWithin the returned Upload object, there is a nested [File](/docs/api-reference/files/object) object that is ready to use in the rest of the platform.\n\nYou can specify the order of the Parts by passing in an ordered list of the Part IDs.\n\nThe number of bytes uploaded upon completion must match the number of bytes initially specified when creating the Upload object. No Parts may be added after an Upload is completed.\nReturns the Upload object with status `completed`, including an additional `file` property containing the created usable File object.\n",
          "pathParams": [
            {
              "name": "upload_id",
              "type": {
                "kind": "scalar",
                "scalar": "string"
              },
              "required": true,
              "description": "The ID of the Upload.\n",
              "example": "upload_abc123"
            }
          ],
          "requestBody": {
            "contentType": "application/json",
            "type": {
              "kind": "ref",
              "name": "CompleteUploadRequest"
            },
            "required": true,
            "encoding": "json"
          },
          "responses": [
            {
              "status": "200",
              "description": "OK",
              "contentType": "application/json",
              "type": {
                "kind": "ref",
                "name": "Upload"
              }
            }
          ],
          "primaryResponse": {
            "kind": "ref",
            "name": "Upload"
          }
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
      "maxRetries": 2,
      "retryableStatusCodes": [
        408,
        429,
        500,
        502,
        503,
        504
      ],
      "retryConnectionErrors": true,
      "honorRetryAfterHeader": true,
      "backoff": {
        "initialDelayMs": 500,
        "maxDelayMs": 8000,
        "multiplier": 2,
        "jitter": 0.25
      }
    },
    "timeout": {
      "defaultTimeoutMs": 60000
    },
    "errors": {
      "statusCodeMap": {
        "400": "BadRequest",
        "401": "Unauthorized",
        "403": "PermissionDenied",
        "404": "NotFound",
        "409": "Conflict",
        "422": "UnprocessableEntity",
        "429": "RateLimited"
      },
      "clientErrorKind": "API",
      "serverErrorKind": "Internal"
    },
    "userAgent": {
      "sdkIdentifierTemplate": "{package}-{language}/{version}",
      "includeRuntimeVersion": false,
      "aiAgentEnvVars": {
        "CLAUDE_CODE": "claude-code",
        "CURSOR_AGENT": "cursor",
        "CLINE_ACTIVE": "cline",
        "WINDSURF_ACTIVE": "windsurf",
        "COPILOT_AGENT": "copilot"
      }
    },
    "telemetry": {
      "requestIdHeader": "X-Request-ID",
      "headerName": "X-Client-Telemetry",
      "enabledByDefault": false
    },
    "logging": {
      "events": [
        "request.start",
        "request.success",
        "request.retry",
        "request.rate_limited",
        "request.error",
        "request.connection_error"
      ]
    },
    "idempotency": {
      "headerName": "Idempotency-Key",
      "autoGenerateForPost": true
    },
    "pagination": {
      "autoPageDelayMs": 0
    },
    "requestGuard": {
      "optionKeys": [
        "api_key",
        "apiKey",
        "idempotency_key",
        "idempotencyKey",
        "extra_headers",
        "extraHeaders",
        "max_retries",
        "maxRetries",
        "base_url",
        "baseUrl",
        "timeout"
      ]
    }
  }
}
