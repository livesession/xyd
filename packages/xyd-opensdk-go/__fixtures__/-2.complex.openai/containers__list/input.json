    }
  ],
  "types": [
    {
      "name": "ContainersListOrder",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "asc"
        },
        {
          "value": "desc"
        }
      ]
    },
    {
      "name": "ContainerListResource",
      "kind": "struct",
      "fields": [
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "list"
          },
          "required": true,
          "description": "The type of object returned, must be 'list'."
        },
        {
          "name": "data",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "ContainerResource"
            }
          },
          "required": true,
          "description": "A list of containers."
        },
        {
          "name": "first_id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The ID of the first container in the list."
        },
        {
          "name": "last_id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The ID of the last container in the list."
        },
        {
          "name": "has_more",
          "type": {
            "kind": "scalar",
            "scalar": "boolean"
          },
          "required": true,
          "description": "Whether there are more containers available."
        }
      ]
    },
    {
      "name": "ContainerResource",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Unique identifier for the container."
        },
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The type of this object."
        },
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Name of the container."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "Unix timestamp (in seconds) when the container was created."
        },
        {
          "name": "status",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Status of the container (e.g., active, deleted)."
        },
        {
          "name": "last_active_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": false,
          "description": "Unix timestamp (in seconds) when the container was last active."
        },
        {
          "name": "expires_after",
          "type": {
            "kind": "ref",
            "name": "ContainerResourceExpiresAfter"
          },
          "required": false,
          "description": "The container will expire after this time period.\nThe anchor is the reference point for the expiration.\nThe minutes is the number of minutes after the anchor before the container expires.\n"
        },
        {
          "name": "memory_limit",
          "type": {
            "kind": "ref",
            "name": "ContainerResourceMemoryLimit"
          },
          "required": false,
          "description": "The memory limit configured for the container."
        },
        {
          "name": "network_policy",
          "type": {
            "kind": "ref",
            "name": "ContainerResourceNetworkPolicy"
          },
          "required": false,
          "description": "Network access policy for the container."
        }
      ]
    },
    {
      "name": "ContainerResourceExpiresAfter",
      "kind": "struct",
      "fields": [
        {
          "name": "anchor",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "last_active_at"
          },
          "required": false,
          "description": "The reference point for the expiration."
        },
        {
          "name": "minutes",
          "type": {
            "kind": "scalar",
            "scalar": "integer"
          },
          "required": false,
          "description": "The number of minutes after the anchor before the container expires."
        }
      ],
      "description": "The container will expire after this time period.\nThe anchor is the reference point for the expiration.\nThe minutes is the number of minutes after the anchor before the container expires.\n"
    },
    {
      "name": "ContainerResourceMemoryLimit",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "1g"
        },
        {
          "value": "4g"
        },
        {
          "value": "16g"
        },
        {
          "value": "64g"
        }
      ],
      "description": "The memory limit configured for the container."
    },
    {
      "name": "ContainerResourceNetworkPolicy",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "ref",
            "name": "ContainerResourceNetworkPolicyType"
          },
          "required": true,
          "description": "The network policy mode."
        },
        {
          "name": "allowed_domains",
          "type": {
            "kind": "array",
            "items": {
              "kind": "scalar",
              "scalar": "string"
            }
          },
          "required": false,
          "description": "Allowed outbound domains when `type` is `allowlist`."
        }
      ],
      "description": "Network access policy for the container."
    },
    {
      "name": "ContainerResourceNetworkPolicyType",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "allowlist"
        },
        {
          "value": "disabled"
        }
      ],
      "description": "The network policy mode."
    }
  ],
  "resources": [
