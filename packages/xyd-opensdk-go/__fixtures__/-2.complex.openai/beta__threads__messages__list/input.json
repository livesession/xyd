      "name": "MessageObjectAttachmentsItemToolsItem",
      "kind": "union",
      "semantics": "oneOf",
      "variants": [
        {
          "kind": "ref",
          "name": "AssistantToolsCode"
        },
        {
          "kind": "ref",
          "name": "AssistantToolsFileSearchTypeOnly"
        }
      ]
    },
    {
      "name": "AssistantToolsCode",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "code_interpreter"
          },
          "required": true,
          "description": "The type of tool being defined: `code_interpreter`"
        }
      ]
    },
    {
      "name": "AssistantToolsFileSearchTypeOnly",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "file_search"
          },
          "required": true,
          "description": "The type of tool being defined: `file_search`"
        }
      ]
    },
    {
      "name": "Metadata",
      "kind": "alias",
      "of": {
        "kind": "map",
        "values": {
          "kind": "scalar",
          "scalar": "string"
        },
        "nullable": true
      }
    }
  ],
  "resources": [
    {
      "name": "beta",
      "resources": [
        {
          "name": "threads",
          "resources": [
            {
              "name": "messages",
              "methods": [
                {
                  "action": "list",
                  "httpMethod": "get",
                  "path": "/threads/{thread_id}/messages",
                  "operationId": "listMessages",
                  "description": "Returns a list of messages for a given thread.",
                  "pathParams": [
                    {
                      "name": "thread_id",
                      "type": {
                        "kind": "scalar",
                        "scalar": "string"
                      },
                      "required": true,
                      "description": "The ID of the [thread](/docs/api-reference/threads) the messages belong to."
                    }
                  ],
                  "queryParams": [
                    {
                      "name": "limit",
                      "type": {
                        "kind": "scalar",
                        "scalar": "integer"
                      },
                      "required": false,
                      "description": "A limit on the number of objects to be returned. Limit can range between 1 and 100, and the default is 20.\n",
                      "default": 20
                    },
                    {
                      "name": "order",
                      "type": {
                        "kind": "ref",
                        "name": "BetaThreadsMessagesListOrder"
                      },
                      "required": false,
                      "description": "Sort order by the `created_at` timestamp of the objects. `asc` for ascending order and `desc` for descending order.\n",
                      "default": "desc"
                    },
                    {
                      "name": "after",
                      "type": {
                        "kind": "scalar",
                        "scalar": "string"
                      },
                      "required": false,
                      "description": "A cursor for use in pagination. `after` is an object ID that defines your place in the list. For instance, if you make a list request and receive 100 objects, ending with obj_foo, your subsequent call can include after=obj_foo in order to fetch the next page of the list.\n"
                    },
                    {
                      "name": "before",
                      "type": {
                        "kind": "scalar",
                        "scalar": "string"
                      },
                      "required": false,
                      "description": "A cursor for use in pagination. `before` is an object ID that defines your place in the list. For instance, if you make a list request and receive 100 objects, starting with obj_foo, your subsequent call can include before=obj_foo in order to fetch the previous page of the list.\n"
                    },
                    {
                      "name": "run_id",
                      "type": {
                        "kind": "scalar",
                        "scalar": "string"
                      },
                      "required": false,
                      "description": "Filter messages by the run ID that generated them.\n"
                    }
                  ],
                  "responses": [
                    {
                      "status": "200",
                      "description": "OK",
                      "contentType": "application/json",
                      "type": {
                        "kind": "ref",
                        "name": "ListMessagesResponse"
                      }
                    }
                  ],
                  "primaryResponse": {
                    "kind": "ref",
                    "name": "ListMessagesResponse"
                  },
                  "pagination": {
                    "style": "cursor",
                    "itemsField": "data",
                    "nextField": "has_more",
                    "itemType": {
                      "kind": "ref",
                      "name": "MessageObject"
                    },
                    "cursorParam": "after",
                    "limitParam": "limit"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
