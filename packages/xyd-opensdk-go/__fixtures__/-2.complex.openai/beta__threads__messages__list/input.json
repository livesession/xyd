            "kind": "scalar",
            "scalar": "string"
          },
          "required": true
        },
        {
          "name": "last_id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true
        },
        {
          "name": "has_more",
          "type": {
            "kind": "scalar",
            "scalar": "boolean"
          },
          "required": true
        }
      ]
    },
    {
      "name": "MessageObject",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The identifier, which can be referenced in API endpoints."
