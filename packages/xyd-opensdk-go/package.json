{
  "name": "@xyd-js/opensdk-go",
  "version": "0.1.0-build.0",
  "description": "OpenSDK IR -> a buildable, idiomatic Go SDK (Stainless/openai-go shaped): client, resource services, typed methods, named types, and a vendored runtime",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run",
    "format": "bunx biome check --write src"
  },
  "dependencies": {
    "@xyd-js/opensdk-core": "workspace:*",
    "@xyd-js/opensdk-framework": "workspace:*"
  },
  "devDependencies": {
    "@xyd-js/openapi": "workspace:*",
    "@xyd-js/openapi2opensdk": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.9.0",
    "js-yaml": "^4.1.0",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1",
    "@xyd-js/opensdk-ci": "workspace:*"
  }
}
