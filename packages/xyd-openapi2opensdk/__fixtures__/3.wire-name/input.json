{
  "openapi": "3.1.0",
  "info": { "title": "Wire Names", "version": "1.0.0" },
  "paths": {
    "/items": {
      "get": {
        "operationId": "listItems",
        "summary": "List items",
        "parameters": [
          {
            "name": "ids[]",
            "in": "query",
            "style": "form",
            "explode": true,
            "schema": { "type": "array", "items": { "type": "string" } }
          },
          { "name": "ids", "in": "query", "schema": { "type": "string" } },
          {
            "name": "sort",
            "in": "query",
            "deprecated": true,
            "example": "asc",
            "schema": { "type": "string", "default": "desc" }
          },
          { "name": "filter.name", "in": "query", "schema": { "type": "string", "example": "widget" } }
        ],
        "responses": {
          "200": {
            "description": "A page of items.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
