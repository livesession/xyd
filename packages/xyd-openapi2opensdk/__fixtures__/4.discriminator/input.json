{
  "openapi": "3.0.3",
  "info": { "title": "Discriminators", "version": "1.0.0" },
  "components": {
    "schemas": {
      "Cat": {
        "type": "object",
        "required": ["pet_type"],
        "properties": {
          "pet_type": { "type": "string" },
          "meows": { "type": "boolean" }
        }
      },
      "Dog": {
        "type": "object",
        "required": ["pet_type"],
        "properties": {
          "pet_type": { "type": "string" },
          "barks": { "type": "boolean" }
        }
      },
      "Pet": {
        "oneOf": [{ "$ref": "#/components/schemas/Cat" }, { "$ref": "#/components/schemas/Dog" }],
        "discriminator": {
          "propertyName": "pet_type",
          "mapping": {
            "cat": "#/components/schemas/Cat",
            "dog": "Dog",
            "ghost": "#/components/schemas/DoesNotExist"
          }
        }
      },
      "Car": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["car"] },
          "wheels": { "type": "integer" }
        }
      },
      "Bike": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "bike" }
        }
      },
      "Vehicle": {
        "oneOf": [{ "$ref": "#/components/schemas/Car" }, { "$ref": "#/components/schemas/Bike" }],
        "discriminator": { "propertyName": "type" }
      }
    }
  },
  "paths": {
    "/pets": {
      "post": {
        "operationId": "createPet",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Pet" } } }
        },
        "responses": {
          "200": {
            "description": "The vehicle the pet drives away in.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Vehicle" } } }
          }
        }
      }
    }
  }
}
