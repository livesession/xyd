{
  "name": "@xyd-js/openapi2opensdk",
  "version": "0.1.0-build.0",
  "description": "OpenAPI 3.x -> OpenSDK IR converter (nominal type resolution + resource/method tree), plus the openai-go conformance oracle",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run",
    "format": "bunx biome check --write src"
  },
  "dependencies": {
    "@xyd-js/opensdk-core": "workspace:*",
    "@xyd-js/openapi": "workspace:*",
    "js-yaml": "^4.1.0",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.9.0",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
