{
  "name": "@xyd-js/source-react-babel-runtime",
  "version": "0.1.0-build.1",
  "description": "Babel plugin that injects xyd uniform data onto React components at build time",
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js"
    },
    "./babel-plugin": {
      "import": "./dist/babel-plugin.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run"
  },
  "dependencies": {
    "@xyd-js/sources": "workspace:*",
    "@xyd-js/uniform": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/babel__core": "^7.20.5",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0"
  }
}
