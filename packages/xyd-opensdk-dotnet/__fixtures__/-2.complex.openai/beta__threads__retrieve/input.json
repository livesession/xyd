{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "ThreadObject",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The identifier, which can be referenced in API endpoints."
        },
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "thread"
          },
          "required": true,
          "description": "The object type, which is always `thread`."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "The Unix timestamp (in seconds) for when the thread was created."
        },
        {
          "name": "tool_resources",
          "type": {
            "kind": "ref",
            "name": "ThreadObjectToolResources",
            "nullable": true
          },
          "required": true
        },
        {
          "name": "metadata",
          "type": {
            "kind": "ref",
            "name": "Metadata"
          },
          "required": true
        }
      ],
      "description": "Represents a thread that contains [messages](/docs/api-reference/messages)."
    },
    {
      "name": "ThreadObjectToolResources",
      "kind": "struct",
      "fields": [
        {
          "name": "code_interpreter",
          "type": {
            "kind": "ref",
            "name": "ThreadObjectToolResourcesCodeInterpreter"
          },
          "required": false
        },
        {
          "name": "file_search",
          "type": {
            "kind": "ref",
            "name": "ThreadObjectToolResourcesFileSearch"
          },
          "required": false
        }
      ],
      "description": "A set of resources that are made available to the assistant's tools in this thread. The resources are specific to the type of tool. For example, the `code_interpreter` tool requires a list of file IDs, while the `file_search` tool requires a list of vector store IDs.\n"
    },
    {
      "name": "ThreadObjectToolResourcesCodeInterpreter",
      "kind": "struct",
      "fields": [
        {
          "name": "file_ids",
          "type": {
            "kind": "array",
            "items": {
              "kind": "scalar",
              "scalar": "string"
            }
          },
          "required": false,
          "default": [],
          "description": "A list of [file](/docs/api-reference/files) IDs made available to the `code_interpreter` tool. There can be a maximum of 20 files associated with the tool.\n"
        }
      ]
    },
    {
      "name": "ThreadObjectToolResourcesFileSearch",
      "kind": "struct",
      "fields": [
        {
          "name": "vector_store_ids",
          "type": {
            "kind": "array",
            "items": {
              "kind": "scalar",
              "scalar": "string"
            }
          },
          "required": false,
          "description": "The [vector store](/docs/api-reference/vector-stores/object) attached to this thread. There can be a maximum of 1 vector store attached to the thread.\n"
        }
      ]
    },
    {
      "name": "Metadata",
      "kind": "alias",
      "of": {
        "kind": "map",
        "values": {
          "kind": "scalar",
          "scalar": "string"
        },
        "nullable": true
      }
    }
  ],
  "resources": [
    {
      "name": "beta",
      "resources": [
        {
          "name": "threads",
          "methods": [
            {
              "action": "retrieve",
              "httpMethod": "get",
              "path": "/threads/{thread_id}",
              "operationId": "getThread",
              "description": "Retrieves a thread.",
              "pathParams": [
                {
                  "name": "thread_id",
                  "type": {
                    "kind": "scalar",
                    "scalar": "string"
                  },
                  "required": true,
                  "description": "The ID of the thread to retrieve."
                }
              ],
              "responses": [
                {
                  "status": "200",
                  "description": "OK",
                  "contentType": "application/json",
                  "type": {
                    "kind": "ref",
                    "name": "ThreadObject"
                  }
                }
              ],
              "primaryResponse": {
                "kind": "ref",
                "name": "ThreadObject"
              }
            }
          ]
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
      "maxRetries": 2,
      "retryableStatusCodes": [
        408,
        429,
        500,
        502,
        503,
        504
      ],
      "retryConnectionErrors": true,
      "honorRetryAfterHeader": true,
      "backoff": {
        "initialDelayMs": 500,
        "maxDelayMs": 8000,
        "multiplier": 2,
        "jitter": 0.25
      }
    },
    "timeout": {
      "defaultTimeoutMs": 60000
    },
    "errors": {
      "statusCodeMap": {
        "400": "BadRequest",
        "401": "Unauthorized",
        "403": "PermissionDenied",
        "404": "NotFound",
        "409": "Conflict",
        "422": "UnprocessableEntity",
        "429": "RateLimited"
      },
      "clientErrorKind": "API",
      "serverErrorKind": "Internal"
    },
    "userAgent": {
      "sdkIdentifierTemplate": "{package}-{language}/{version}",
      "includeRuntimeVersion": false,
      "aiAgentEnvVars": {
        "CLAUDE_CODE": "claude-code",
        "CURSOR_AGENT": "cursor",
        "CLINE_ACTIVE": "cline",
        "WINDSURF_ACTIVE": "windsurf",
        "COPILOT_AGENT": "copilot"
      }
    },
    "telemetry": {
      "requestIdHeader": "X-Request-ID",
      "headerName": "X-Client-Telemetry",
      "enabledByDefault": false
    },
    "logging": {
      "events": [
        "request.start",
        "request.success",
        "request.retry",
        "request.rate_limited",
        "request.error",
        "request.connection_error"
      ]
    },
    "idempotency": {
      "headerName": "Idempotency-Key",
      "autoGenerateForPost": true
    },
    "pagination": {
      "autoPageDelayMs": 0
    },
    "requestGuard": {
      "optionKeys": [
        "api_key",
        "apiKey",
        "idempotency_key",
        "idempotencyKey",
        "extra_headers",
        "extraHeaders",
        "max_retries",
        "maxRetries",
        "base_url",
        "baseUrl",
        "timeout"
      ]
    }
  }
}
