{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "CreateThreadRequest",
      "kind": "struct",
      "fields": [
        {
          "name": "messages",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "CreateMessageRequest"
            }
          },
          "required": false,
          "description": "A list of [messages](/docs/api-reference/messages) to start the thread with."
        },
        {
          "name": "tool_resources",
          "type": {
            "kind": "ref",
            "name": "CreateThreadRequestToolResources",
            "nullable": true
          },
          "required": false
        },
        {
          "name": "metadata",
          "type": {
            "kind": "ref",
            "name": "Metadata"
          },
          "required": false
        }
      ],
      "description": "Options to create a new thread. If no thread is provided when running a\nrequest, an empty thread will be created.\n"
    },
    {
      "name": "CreateMessageRequest",
      "kind": "struct",
      "fields": [
        {
          "name": "role",
          "type": {
            "kind": "ref",
            "name": "CreateMessageRequestRole"
          },
          "required": true,
          "description": "The role of the entity that is creating the message. Allowed values include:\n- `user`: Indicates the message is sent by an actual user and should be used in most cases to represent user-generated messages.\n- `assistant`: Indicates the message is generated by the assistant. Use this value to insert messages from the assistant into the conversation.\n"
        },
        {
          "name": "content",
          "type": {
            "kind": "ref",
            "name": "CreateMessageRequestContent"
          },
          "required": true
        },
        {
          "name": "attachments",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "CreateMessageRequestAttachmentsItem"
            },
            "nullable": true
          },
          "required": false
        },
        {
          "name": "metadata",
          "type": {
            "kind": "ref",
            "name": "Metadata"
          },
          "required": false
        }
      ]
    },
    {
      "name": "CreateMessageRequestRole",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "user"
        },
        {
          "value": "assistant"
        }
      ],
      "description": "The role of the entity that is creating the message. Allowed values include:\n- `user`: Indicates the message is sent by an actual user and should be used in most cases to represent user-generated messages.\n- `assistant`: Indicates the message is generated by the assistant. Use this value to insert messages from the assistant into the conversation.\n"
    },
    {
      "name": "CreateMessageRequestContent",
      "kind": "union",
      "semantics": "oneOf",
      "variants": [
        {
          "kind": "scalar",
          "scalar": "string"
        },
        {
          "kind": "array",
          "items": {
            "kind": "ref",
            "name": "CreateMessageRequestContentArrayOfContentPartsItem"
          }
        }
      ]
    },
    {
      "name": "CreateMessageRequestContentArrayOfContentPartsItem",
      "kind": "union",
      "semantics": "oneOf",
      "variants": [
        {
          "kind": "ref",
          "name": "MessageContentImageFileObject"
        },
        {
          "kind": "ref",
          "name": "MessageContentImageUrlObject"
        },
        {
          "kind": "ref",
          "name": "MessageRequestContentTextObject"
        }
      ]
    },
    {
      "name": "MessageContentImageFileObject",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "image_file"
          },
          "required": true,
          "description": "Always `image_file`."
        },
        {
          "name": "image_file",
          "type": {
            "kind": "ref",
            "name": "MessageContentImageFileObjectImageFile"
          },
          "required": true
        }
      ],
      "description": "References an image [File](/docs/api-reference/files) in the content of a message."
    },
    {
      "name": "MessageContentImageFileObjectImageFile",
      "kind": "struct",
      "fields": [
        {
          "name": "file_id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The [File](/docs/api-reference/files) ID of the image in the message content. Set `purpose=\"vision\"` when uploading the File if you need to later display the file content."
        },
        {
          "name": "detail",
          "type": {
            "kind": "ref",
            "name": "MessageContentImageFileObjectImageFileDetail"
          },
          "required": false,
          "default": "auto",
          "description": "Specifies the detail level of the image if specified by the user. `low` uses fewer tokens, you can opt in to high resolution using `high`."
        }
      ]
    },
    {
      "name": "MessageContentImageFileObjectImageFileDetail",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "auto"
        },
        {
          "value": "low"
        },
        {
          "value": "high"
        }
      ],
      "description": "Specifies the detail level of the image if specified by the user. `low` uses fewer tokens, you can opt in to high resolution using `high`."
    },
    {
      "name": "MessageContentImageUrlObject",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "image_url"
          },
          "required": true,
          "description": "The type of the content part."
        },
        {
          "name": "image_url",
          "type": {
            "kind": "ref",
            "name": "MessageContentImageUrlObjectImageUrl"
          },
          "required": true
        }
      ],
      "description": "References an image URL in the content of a message."
    },
    {
      "name": "MessageContentImageUrlObjectImageUrl",
      "kind": "struct",
      "fields": [
        {
          "name": "url",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "format": "uri"
          },
          "required": true,
          "description": "The external URL of the image, must be a supported image types: jpeg, jpg, png, gif, webp."
        },
        {
          "name": "detail",
          "type": {
            "kind": "ref",
            "name": "MessageContentImageFileObjectImageFileDetail"
          },
          "required": false,
          "default": "auto",
          "description": "Specifies the detail level of the image. `low` uses fewer tokens, you can opt in to high resolution using `high`. Default value is `auto`"
        }
      ]
    },
    {
      "name": "MessageRequestContentTextObject",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "text"
          },
          "required": true,
          "description": "Always `text`."
        },
        {
          "name": "text",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "Text content to be sent to the model"
        }
      ],
      "description": "The text content that is part of a message."
    },
    {
      "name": "CreateMessageRequestAttachmentsItem",
      "kind": "struct",
      "fields": [
        {
          "name": "file_id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": false,
          "description": "The ID of the file to attach to the message."
        },
        {
          "name": "tools",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "CreateMessageRequestAttachmentsItemToolsItem"
            }
          },
          "required": false,
          "description": "The tools to add this file to."
        }
      ]
    },
    {
      "name": "CreateMessageRequestAttachmentsItemToolsItem",
      "kind": "union",
      "semantics": "oneOf",
      "variants": [
        {
          "kind": "ref",
          "name": "AssistantToolsCode"
        },
        {
          "kind": "ref",
          "name": "AssistantToolsFileSearchTypeOnly"
        }
      ]
    },
    {
      "name": "AssistantToolsCode",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "code_interpreter"
          },
          "required": true,
          "description": "The type of tool being defined: `code_interpreter`"
        }
      ]
    },
    {
      "name": "AssistantToolsFileSearchTypeOnly",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "file_search"
          },
          "required": true,
          "description": "The type of tool being defined: `file_search`"
        }
      ]
    },
    {
      "name": "Metadata",
      "kind": "alias",
      "of": {
        "kind": "map",
        "values": {
          "kind": "scalar",
          "scalar": "string"
        },
        "nullable": true
      }
    },
    {
      "name": "CreateThreadRequestToolResources",
      "kind": "struct",
      "fields": [
        {
          "name": "code_interpreter",
          "type": {
            "kind": "ref",
            "name": "CreateThreadRequestToolResourcesCodeInterpreter"
          },
          "required": false
        },
        {
          "name": "file_search",
          "type": {
            "kind": "ref",
            "name": "CreateThreadRequestToolResourcesFileSearch"
          },
          "required": false
        }
      ],
      "description": "A set of resources that are made available to the assistant's tools in this thread. The resources are specific to the type of tool. For example, the `code_interpreter` tool requires a list of file IDs, while the `file_search` tool requires a list of vector store IDs.\n"
    },
    {
      "name": "CreateThreadRequestToolResourcesCodeInterpreter",
      "kind": "struct",
      "fields": [
        {
          "name": "file_ids",
          "type": {
            "kind": "array",
            "items": {
              "kind": "scalar",
              "scalar": "string"
            }
          },
          "required": false,
          "default": [],
          "description": "A list of [file](/docs/api-reference/files) IDs made available to the `code_interpreter` tool. There can be a maximum of 20 files associated with the tool.\n"
        }
      ]
    },
    {
      "name": "CreateThreadRequestToolResourcesFileSearch",
      "kind": "union",
      "semantics": "oneOf",
      "variants": [
        {
          "kind": "any"
        },
        {
          "kind": "any"
        }
      ]
    },
    {
      "name": "ThreadObject",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The identifier, which can be referenced in API endpoints."
        },
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "thread"
          },
          "required": true,
          "description": "The object type, which is always `thread`."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "The Unix timestamp (in seconds) for when the thread was created."
        },
        {
          "name": "tool_resources",
          "type": {
            "kind": "ref",
            "name": "ThreadObjectToolResources",
            "nullable": true
          },
          "required": true
        },
        {
          "name": "metadata",
          "type": {
            "kind": "ref",
            "name": "Metadata"
          },
          "required": true
        }
      ],
      "description": "Represents a thread that contains [messages](/docs/api-reference/messages)."
    },
    {
      "name": "ThreadObjectToolResources",
      "kind": "struct",
      "fields": [
        {
          "name": "code_interpreter",
          "type": {
            "kind": "ref",
            "name": "CreateThreadRequestToolResourcesCodeInterpreter"
          },
          "required": false
        },
        {
          "name": "file_search",
          "type": {
            "kind": "ref",
            "name": "ThreadObjectToolResourcesFileSearch"
          },
          "required": false
        }
      ],
      "description": "A set of resources that are made available to the assistant's tools in this thread. The resources are specific to the type of tool. For example, the `code_interpreter` tool requires a list of file IDs, while the `file_search` tool requires a list of vector store IDs.\n"
    },
    {
      "name": "ThreadObjectToolResourcesFileSearch",
      "kind": "struct",
      "fields": [
        {
          "name": "vector_store_ids",
          "type": {
            "kind": "array",
            "items": {
              "kind": "scalar",
              "scalar": "string"
            }
          },
          "required": false,
          "description": "The [vector store](/docs/api-reference/vector-stores/object) attached to this thread. There can be a maximum of 1 vector store attached to the thread.\n"
        }
      ]
    }
  ],
  "resources": [
    {
      "name": "beta",
      "resources": [
        {
          "name": "threads",
          "methods": [
            {
              "action": "create",
              "httpMethod": "post",
              "path": "/threads",
              "operationId": "createThread",
              "description": "Create a thread.",
              "requestBody": {
                "contentType": "application/json",
                "type": {
                  "kind": "ref",
                  "name": "CreateThreadRequest"
                },
                "required": false,
                "encoding": "json"
              },
              "responses": [
                {
                  "status": "200",
                  "description": "OK",
                  "contentType": "application/json",
                  "type": {
                    "kind": "ref",
                    "name": "ThreadObject"
                  }
                }
              ],
              "primaryResponse": {
                "kind": "ref",
                "name": "ThreadObject"
              }
            }
          ]
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
      "maxRetries": 2,
      "retryableStatusCodes": [
        408,
        429,
        500,
        502,
        503,
        504
      ],
      "retryConnectionErrors": true,
      "honorRetryAfterHeader": true,
      "backoff": {
        "initialDelayMs": 500,
        "maxDelayMs": 8000,
        "multiplier": 2,
        "jitter": 0.25
      }
    },
    "timeout": {
      "defaultTimeoutMs": 60000
    },
    "errors": {
      "statusCodeMap": {
        "400": "BadRequest",
        "401": "Unauthorized",
        "403": "PermissionDenied",
        "404": "NotFound",
        "409": "Conflict",
        "422": "UnprocessableEntity",
        "429": "RateLimited"
      },
      "clientErrorKind": "API",
      "serverErrorKind": "Internal"
    },
    "userAgent": {
      "sdkIdentifierTemplate": "{package}-{language}/{version}",
      "includeRuntimeVersion": false,
      "aiAgentEnvVars": {
        "CLAUDE_CODE": "claude-code",
        "CURSOR_AGENT": "cursor",
        "CLINE_ACTIVE": "cline",
        "WINDSURF_ACTIVE": "windsurf",
        "COPILOT_AGENT": "copilot"
      }
    },
    "telemetry": {
      "requestIdHeader": "X-Request-ID",
      "headerName": "X-Client-Telemetry",
      "enabledByDefault": false
    },
    "logging": {
      "events": [
        "request.start",
        "request.success",
        "request.retry",
        "request.rate_limited",
        "request.error",
        "request.connection_error"
      ]
    },
    "idempotency": {
      "headerName": "Idempotency-Key",
      "autoGenerateForPost": true
    },
    "pagination": {
      "autoPageDelayMs": 0
    },
    "requestGuard": {
      "optionKeys": [
        "api_key",
        "apiKey",
        "idempotency_key",
        "idempotencyKey",
        "extra_headers",
        "extraHeaders",
        "max_retries",
        "maxRetries",
        "base_url",
        "baseUrl",
        "timeout"
      ]
    }
  }
}
