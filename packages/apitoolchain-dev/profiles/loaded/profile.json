      "languages": ["node", "python"]
    },
    {
      "api": "Catalog API",
      "name": "Catalog SDK",
      "languages": ["node", "java"]
    },
    {
      "api": "Inventory API",
      "name": "Inventory SDK",
      "languages": ["node", "go", "python", "java"]
    },
    {
      "api": "Shipping API",
      "name": "Shipping SDK",
      "languages": ["go", "dotnet"]
    },
    {
      "api": "LiveSession API",
      "name": "LiveSession SDK",
      "languages": ["node", "go", "python"]
    }
  ],
  "projects": [
    { "name": "Staging" },
    { "name": "Production" },
    { "name": "Sandbox" }
  ],
  "members": [
