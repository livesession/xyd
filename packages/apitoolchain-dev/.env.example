# apitoolchain dev-stack credentials + config.
#
# Copy to `.env` (gitignored) and edit, or just rely on these defaults. Precedence
# is: real environment  >  packages/apitoolchain-dev/.env  >  this file. The dev
# vite plugin loads them at boot (see loadDevEnv in src/vite.ts).

# ── Dev owner (the seeded account the profile logs the browser in as) ──
ATC_DEV_EMAIL=dev@apitoolchain.dev
ATC_DEV_PASSWORD=password

# ── Local package registries ──
# FIXED host ports so a published SDK's registry URL survives a dev-server
# restart / snapshot restore (random ports would go stale and publishes hang).
# Change if a port clashes with something already running.
ATC_VERDACCIO_PORT=4873
ATC_PYPI_PORT=8081
ATC_GEMS_PORT=9292

# Auth token used when publishing to the LOCAL registries. They're anonymous
# (verdaccio `$all`), so any non-empty value works — the npm client just refuses
# to publish without SOME token. Point at a real registry + real token to publish
# for real.
ATC_PUBLISH_TOKEN=dev
