                            "kind": "array",
                            "items": {
                              "kind": "scalar",
                              "scalar": "string"
                            }
                          },
                          "required": false,
                          "description": "Return only usage for these models."
                        },
                        {
                          "name": "batch",
                          "type": {
                            "kind": "scalar",
                            "scalar": "boolean"
                          },
                          "required": false,
                          "description": "If `true`, return batch jobs only. If `false`, return non-batch jobs only. By default, return both.\n"
                        },
