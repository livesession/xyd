                          },
                          "required": false,
                          "description": "Width of each time bucket in response. Currently `1m`, `1h` and `1d` are supported, default to `1d`.",
                          "default": "1d"
                        },
                        {
                          "name": "project_ids",
                          "type": {
                            "kind": "array",
                            "items": {
                              "kind": "scalar",
                              "scalar": "string"
                            }
                          },
                          "required": false,
                          "description": "Return only usage for these projects."
                        },
                        {
                          "name": "user_ids",
                          "type": {
