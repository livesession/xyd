                {
                  "name": "steps",
                  "methods": [
                    {
                      "action": "retrieve",
                      "httpMethod": "get",
                      "path": "/threads/{thread_id}/runs/{run_id}/steps/{step_id}",
                      "operationId": "getRunStep",
                      "description": "Retrieves a run step.",
                      "pathParams": [
                        {
                          "name": "thread_id",
                          "type": {
                            "kind": "scalar",
                            "scalar": "string"
                          },
                          "required": true,
                          "description": "The ID of the thread to which the run and run step belongs."
                        },
                        {
                          "name": "run_id",
                          "type": {
                            "kind": "scalar",
                            "scalar": "string"
                          },
                          "required": true,
                          "description": "The ID of the run to which the run step belongs."
                        },
                        {
                          "name": "step_id",
                          "type": {
                            "kind": "scalar",
                            "scalar": "string"
                          },
                          "required": true,
                          "description": "The ID of the run step to retrieve."
                        }
                      ],
                      "queryParams": [
                        {
                          "name": "include",
                          "type": {
                            "kind": "array",
                            "items": {
                              "kind": "scalar",
                              "scalar": "string",
                              "const": "step_details.tool_calls[*].file_search.results[*].content"
                            }
                          },
                          "required": false,
                          "wireName": "include[]",
                          "description": "A list of additional fields to include in the response. Currently the only supported value is `step_details.tool_calls[*].file_search.results[*].content` to fetch the file search result content.\n\nSee the [file search tool documentation](/docs/assistants/tools/file-search#customizing-file-search-settings) for more information.\n"
                        }
                      ],
                      "responses": [
                        {
                          "status": "200",
                          "description": "OK",
                          "contentType": "application/json",
                          "type": {
                            "kind": "ref",
                            "name": "RunStepObject"
                          }
                        }
                      ],
                      "primaryResponse": {
                        "kind": "ref",
                        "name": "RunStepObject"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
