{
  "name": "@xyd-js/source-react-runtime",
  "version": "0.1.0-build.1",
  "description": "Build plugin (Vite, Rollup, esbuild) that auto-detects React components and injects runtime type metadata using typia and xyd uniform format",
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js"
    },
    "./esbuild": {
      "import": "./dist/esbuild.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run"
  },
  "dependencies": {
    "typia": "^12.0.0",
    "@xyd-js/openapi": "workspace:*",
    "@xyd-js/uniform": "workspace:*"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.0",
    "@react-router/node": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/router-plugin": "^1.167.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.25.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.14.0",
    "rimraf": "^3.0.2",
    "rollup": "^4.55.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^2.1.8"
  }
}
