{
  "name": "@xyd-js/opencli-completion",
  "version": "0.1.0-build.0",
  "description": "Generate shell completion scripts (zsh, fish) from an OpenCLI document",
  "main": "./dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run",
    "format": "bunx biome check --write src"
  },
  "dependencies": {
    "@xyd-js/opencli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
