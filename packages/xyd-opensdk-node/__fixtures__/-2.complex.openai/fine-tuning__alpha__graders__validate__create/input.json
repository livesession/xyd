        },
        {
          "kind": "ref",
          "name": "EvalItemContentOutputText"
        },
        {
          "kind": "ref",
          "name": "EvalItemInputImage"
        },
        {
          "kind": "ref",
          "name": "InputAudio"
        }
      ],
      "description": "A single content item: input text, output text, input image, or input audio.\n"
    },
