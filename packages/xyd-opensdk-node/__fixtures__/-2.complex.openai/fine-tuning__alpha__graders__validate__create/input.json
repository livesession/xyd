        {
          "value": "fuzzy_match"
        },
        {
          "value": "bleu"
        },
        {
          "value": "gleu"
        },
        {
          "value": "meteor"
        },
        {
          "value": "rouge_1"
        },
        {
          "value": "rouge_2"
        },
        {
          "value": "rouge_3"
        },
        {
          "value": "rouge_4"
        },
        {
          "value": "rouge_5"
        },
        {
          "value": "rouge_l"
        }
      ],
      "description": "The evaluation metric to use. One of `cosine`, `fuzzy_match`, `bleu`, \n`gleu`, `meteor`, `rouge_1`, `rouge_2`, `rouge_3`, `rouge_4`, `rouge_5`, \nor `rouge_l`.\n"
    },
