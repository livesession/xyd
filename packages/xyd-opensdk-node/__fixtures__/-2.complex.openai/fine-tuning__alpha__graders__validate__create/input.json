      "of": {
        "kind": "scalar",
        "scalar": "string"
      }
    },
    {
      "name": "InputTextContent",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "input_text"
          },
          "required": true,
          "default": "input_text",
          "description": "The type of the input item. Always `input_text`."
        },
        {
          "name": "text",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The text input to the model."
        }
      ],
      "description": "A text input to the model."
    },
    {
      "name": "EvalItemContentOutputText",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "output_text"
          },
          "required": true,
          "description": "The type of the output text. Always `output_text`.\n"
        },
        {
          "name": "text",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The text output from the model.\n"
        }
      ],
      "description": "A text output from the model.\n"
    },
    {
      "name": "EvalItemInputImage",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "input_image"
