        }
      ],
      "description": "A PythonGrader object that runs a python script on the input.\n"
    },
    {
      "name": "GraderScoreModel",
      "kind": "struct",
      "fields": [
        {
          "name": "type",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "score_model"
          },
          "required": true,
          "description": "The object type, which is always `score_model`."
        },
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The name of the grader."
        },
        {
          "name": "model",
          "type": {
            "kind": "scalar",
            "scalar": "string"
