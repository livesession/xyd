{
  "name": "@xyd-js/opensdk-uniform",
  "version": "0.1.0-build.0",
  "description": "Enrich Uniform References with OpenSDK usage examples (client + one idiomatic call per language) so Atlas renders SDK code tabs — provider style",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run",
    "format": "bunx biome check --write src"
  },
  "dependencies": {
    "@xyd-js/openapi2opensdk": "workspace:*",
    "@xyd-js/opensdk-core": "workspace:*",
    "@xyd-js/opensdk-dotnet": "workspace:*",
    "@xyd-js/opensdk-framework": "workspace:*",
    "@xyd-js/opensdk-go": "workspace:*",
    "@xyd-js/opensdk-java": "workspace:*",
    "@xyd-js/opensdk-node": "workspace:*",
    "@xyd-js/opensdk-python": "workspace:*",
    "@xyd-js/opensdk-ruby": "workspace:*",
    "@xyd-js/uniform": "workspace:*"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.9.0",
    "@xyd-js/opensdk-ci": "workspace:*",
    "@xyd-js/openapi": "workspace:*",
    "js-yaml": "^4.1.0",
    "openapi-types": "^12.1.3",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
