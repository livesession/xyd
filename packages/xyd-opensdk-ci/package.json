{
  "name": "@xyd-js/opensdk-ci",
  "version": "0.1.0-build.0",
  "description": "OpenSDK test/CI harness: golden file-map fixtures, per-operation spec scoping, compile smokes and the e2e recording server shared by every emitter package",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run",
    "format": "bunx biome check --write src"
  },
  "dependencies": {
    "@xyd-js/opensdk-core": "workspace:*",
    "@xyd-js/opensdk-framework": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@xyd-js/opensdk-go": "workspace:*",
    "@xyd-js/opensdk-python": "workspace:*",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
