{
  "name": "@xyd-js/plugin-access-control",
  "version": "0.0.0",
  "author": "",
  "description": "Access control plugin for xyd documentation sites",
  "license": "MIT",
  "main": "./dist/client.js",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/client.js"
    },
    "./plugin": {
      "import": "./dist/index.js"
    },
    "./AuthGuard": {
      "import": "./dist/AuthGuard.js"
    },
    "./LoginPage": {
      "import": "./dist/LoginPage.js"
    },
    "./AuthCallbackPage": {
      "import": "./dist/AuthCallbackPage.js"
    },
    "./AccessControlContext": {
      "import": "./dist/AccessControlContext.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@linaria/core": "^6.0.0",
    "picomatch": "^4.0.2"
  },
  "peerDependencies": {
    "@xyd-js/core": "workspace:*",
    "@xyd-js/plugins": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "rimraf": "^3.0.2",
    "tsup": "^8.4.0",
    "vite": "^7.0.0",
    "vitest": "^1.6.1"
  }
}
