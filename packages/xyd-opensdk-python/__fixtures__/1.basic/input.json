{
  "opensdk": "1.0.0",
  "info": {
    "title": "Petstore",
    "version": "1.2.0",
    "description": "A tiny pet store API."
  },
  "servers": [
    "https://api.petstore.io/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "envVar": "PETSTORE_API_KEY",
      "scheme": "bearer",
      "bearerFormat": "JWT"
    }
  ],
  "types": [
    {
      "name": "PetList",
      "kind": "struct",
      "fields": [
        {
          "name": "data",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "Pet"
            }
          },
          "required": false
        },
        {
          "name": "has_more",
          "type": {
            "kind": "scalar",
            "scalar": "boolean"
          },
          "required": false
        }
      ]
    },
    {
      "name": "Pet",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "readOnly": true
        },
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true
        },
        {
          "name": "status",
          "type": {
            "kind": "ref",
            "name": "PetStatus"
          },
          "required": false
        },
        {
          "name": "tags",
          "type": {
            "kind": "array",
            "items": {
              "kind": "scalar",
              "scalar": "string"
            }
          },
          "required": false
        }
      ],
      "description": "A pet in the store."
    },
    {
      "name": "PetStatus",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "available"
        },
        {
          "value": "pending"
        },
        {
          "value": "sold"
        }
      ],
      "description": "Pet availability."
    },
    {
      "name": "CreatePetRequest",
      "kind": "struct",
      "fields": [
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true
        },
        {
          "name": "status",
          "type": {
            "kind": "ref",
            "name": "PetStatus"
          },
          "required": false
        }
      ]
    }
  ],
  "resources": [
    {
      "name": "pets",
      "methods": [
        {
          "action": "list",
          "httpMethod": "get",
          "path": "/pets",
          "operationId": "listPets",
          "description": "List pets",
          "queryParams": [
            {
              "name": "after",
              "type": {
                "kind": "scalar",
                "scalar": "string"
              },
              "required": false
            },
            {
              "name": "limit",
              "type": {
                "kind": "scalar",
                "scalar": "integer"
              },
              "required": false
            }
          ],
          "responses": [
            {
              "status": "200",
              "description": "A page of pets.",
              "contentType": "application/json",
              "type": {
                "kind": "ref",
                "name": "PetList"
              }
            }
          ],
          "primaryResponse": {
            "kind": "ref",
            "name": "PetList"
          },
          "pagination": {
            "style": "cursor",
            "itemsField": "data",
            "nextField": "has_more",
            "itemType": {
              "kind": "ref",
              "name": "Pet"
            },
            "cursorParam": "after"
          }
        },
        {
          "action": "create",
          "httpMethod": "post",
          "path": "/pets",
          "operationId": "createPet",
          "description": "Create a pet",
          "requestBody": {
            "contentType": "application/json",
            "type": {
              "kind": "ref",
              "name": "CreatePetRequest"
            },
            "required": true,
            "encoding": "json"
          },
          "responses": [
            {
              "status": "200",
              "description": "The created pet.",
              "contentType": "application/json",
              "type": {
                "kind": "ref",
                "name": "Pet"
              }
            }
          ],
          "primaryResponse": {
            "kind": "ref",
            "name": "Pet"
          }
        },
        {
          "action": "retrieve",
          "httpMethod": "get",
          "path": "/pets/{pet_id}",
          "operationId": "getPet",
          "description": "Retrieve a pet",
          "pathParams": [
            {
              "name": "pet_id",
              "type": {
                "kind": "scalar",
                "scalar": "string"
              },
              "required": true
            }
          ],
          "responses": [
            {
              "status": "200",
              "description": "The pet.",
              "contentType": "application/json",
              "type": {
                "kind": "ref",
                "name": "Pet"
              }
            }
          ],
          "primaryResponse": {
            "kind": "ref",
            "name": "Pet"
          }
        }
      ]
    }
  ]
}
