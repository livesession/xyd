{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "videos",
      "commands": [
        {
          "name": "create",
          "description": "Create a new video generation job from a prompt and optional reference assets.",
          "options": [
            {
              "name": "model",
              "group": "body",
              "description": "The video generation model to use (allowed values: sora-2, sora-2-pro). Defaults to `sora-2`.",
              "arguments": [
                {
                  "name": "value"
                }
              ]
            },
            {
              "name": "prompt",
              "group": "body",
              "required": true,
              "description": "Text prompt that describes the video to generate.",
              "arguments": [
                {
                  "name": "string"
                }
              ]
            },
            {
              "name": "input-reference",
              "group": "body",
              "description": "Optional reference object that guides generation. Provide exactly one of `image_url` or `file_id`.",
              "arguments": [
                {
                  "name": "json"
                }
              ]
            },
            {
              "name": "seconds",
              "group": "body",
              "description": "Clip duration in seconds (allowed values: 4, 8, 12). Defaults to 4 seconds.",
              "arguments": [
                {
                  "name": "string",
                  "acceptedValues": [
                    "4",
                    "8",
                    "12"
                  ]
                }
              ]
            },
            {
              "name": "size",
              "group": "body",
              "description": "Output resolution formatted as width x height (allowed values: 720x1280, 1280x720, 1024x1792, 1792x1024). Defaults to 720x1280.",
              "arguments": [
                {
                  "name": "string",
                  "acceptedValues": [
                    "720x1280",
                    "1280x720",
                    "1024x1792",
                    "1792x1024"
                  ]
                }
              ]
            }
          ],
          "x-openapi": {
            "method": "post",
            "path": "/videos",
            "operationId": "createVideo",
            "contentType": "application/json",
            "body": {
              "style": "flatten",
              "contentType": "application/json",
              "properties": [
                {
                  "name": "model",
                  "from": "option:model",
                  "jsonPath": "model",
                  "encoding": "json"
                },
                {
                  "name": "prompt",
                  "from": "option:prompt",
                  "jsonPath": "prompt",
                  "encoding": "string",
                  "required": true
                },
                {
                  "name": "input_reference",
                  "from": "option:input-reference",
                  "jsonPath": "input_reference",
                  "encoding": "json"
                },
                {
                  "name": "seconds",
                  "from": "option:seconds",
                  "jsonPath": "seconds",
                  "encoding": "string"
                },
                {
                  "name": "size",
                  "from": "option:size",
                  "jsonPath": "size",
                  "encoding": "string"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
