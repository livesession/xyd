{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "organization",
      "commands": [
        {
          "name": "projects",
          "commands": [
            {
              "name": "groups",
              "commands": [
                {
                  "name": "delete",
                  "description": "Revokes a group's access to a project.",
                  "arguments": [
                    {
                      "name": "project-id",
                      "required": true,
                      "description": "The ID of the project to update."
                    },
                    {
                      "name": "group-id",
                      "required": true,
                      "description": "The ID of the group to remove from the project."
                    }
                  ],
                  "x-openapi": {
                    "method": "delete",
                    "path": "/organization/projects/{project_id}/groups/{group_id}",
                    "operationId": "remove-project-group",
                    "params": [
                      {
                        "in": "path",
                        "name": "project_id",
                        "from": "argument:project-id",
                        "required": true
                      },
                      {
                        "in": "path",
                        "name": "group_id",
                        "from": "argument:group-id",
                        "required": true
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
