{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "realtime",
      "commands": [
        {
          "name": "calls",
          "commands": [
            {
              "name": "create",
              "description": "Create a new Realtime API call over WebRTC and receive the SDP answer needed\nto complete the peer connection.",
              "options": [
                {
                  "name": "sdp",
                  "group": "body",
                  "required": true,
                  "description": "WebRTC Session Description Protocol (SDP) offer generated by the caller.",
                  "arguments": [
                    {
                      "name": "string"
                    }
                  ]
                },
                {
                  "name": "session",
                  "group": "body",
                  "description": "Optional session configuration to apply before the realtime session is\ncreated. Use the same parameters you would send in a [`create client secret`](/docs/api-reference/realtime-sessions/create-realtime-client-secret)\nrequest.",
                  "arguments": [
                    {
                      "name": "value"
                    }
                  ]
                }
              ],
              "x-openapi": {
                "method": "post",
                "path": "/realtime/calls",
                "operationId": "create-realtime-call",
                "contentType": "multipart/form-data",
                "body": {
                  "style": "multipart",
                  "contentType": "multipart/form-data",
                  "properties": [
                    {
                      "name": "sdp",
                      "from": "option:sdp",
                      "jsonPath": "sdp",
                      "encoding": "string",
                      "required": true
                    },
                    {
                      "name": "session",
                      "from": "option:session",
                      "jsonPath": "session",
                      "encoding": "json"
                    }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
