{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "vector-stores",
      "commands": [
        {
          "name": "file-batches",
          "commands": [
            {
              "name": "retrieve",
              "aliases": [
                "get"
              ],
              "description": "Retrieves a vector store file batch.",
              "arguments": [
                {
                  "name": "vector-store-id",
                  "required": true,
                  "description": "The ID of the vector store that the file batch belongs to."
                },
                {
                  "name": "batch-id",
                  "required": true,
                  "description": "The ID of the file batch being retrieved."
                }
              ],
              "x-openapi": {
                "method": "get",
                "path": "/vector_stores/{vector_store_id}/file_batches/{batch_id}",
                "operationId": "getVectorStoreFileBatch",
                "params": [
                  {
                    "in": "path",
                    "name": "vector_store_id",
                    "from": "argument:vector-store-id",
                    "required": true
                  },
                  {
                    "in": "path",
                    "name": "batch_id",
                    "from": "argument:batch-id",
                    "required": true
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
