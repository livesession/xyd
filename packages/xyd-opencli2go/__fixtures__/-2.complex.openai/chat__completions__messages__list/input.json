{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "chat",
      "commands": [
        {
          "name": "completions",
          "commands": [
            {
              "name": "messages",
              "commands": [
                {
                  "name": "list",
                  "description": "Get the messages in a stored chat completion. Only Chat Completions that\nhave been created with the `store` parameter set to `true` will be\nreturned.\n",
                  "arguments": [
                    {
                      "name": "completion-id",
                      "required": true,
                      "description": "The ID of the chat completion to retrieve messages from."
                    }
                  ],
                  "options": [
                    {
                      "name": "after",
                      "description": "Identifier for the last message from the previous pagination request.",
                      "group": "query",
                      "arguments": [
                        {
                          "name": "string"
                        }
                      ]
                    },
                    {
                      "name": "limit",
                      "description": "Number of messages to retrieve.",
                      "group": "query",
                      "arguments": [
                        {
                          "name": "integer"
                        }
                      ]
                    },
                    {
                      "name": "order",
                      "description": "Sort order for messages by timestamp. Use `asc` for ascending order or `desc` for descending order. Defaults to `asc`.",
                      "group": "query",
                      "arguments": [
                        {
                          "name": "string",
                          "acceptedValues": [
                            "asc",
                            "desc"
                          ]
                        }
                      ]
                    }
                  ],
                  "x-openapi": {
                    "method": "get",
                    "path": "/chat/completions/{completion_id}/messages",
                    "operationId": "getChatCompletionMessages",
                    "params": [
                      {
                        "in": "path",
                        "name": "completion_id",
                        "from": "argument:completion-id",
                        "required": true
                      },
                      {
                        "in": "query",
                        "name": "after",
                        "from": "option:after"
                      },
                      {
                        "in": "query",
                        "name": "limit",
                        "from": "option:limit"
                      },
                      {
                        "in": "query",
                        "name": "order",
                        "from": "option:order"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
