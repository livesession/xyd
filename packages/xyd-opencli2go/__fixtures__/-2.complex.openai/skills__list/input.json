                    "desc"
                  ]
                }
              ]
            },
            {
              "name": "after",
              "description": "Identifier for the last item from the previous pagination request",
              "group": "query",
              "arguments": [
                {
                  "name": "string"
                }
              ]
            }
          ],
          "x-openapi": {
            "method": "get",
            "path": "/skills",
            "operationId": "ListSkills",
            "params": [
              {
                "in": "query",
                "name": "limit",
                "from": "option:limit"
              },
              {
                "in": "query",
                "name": "order",
                "from": "option:order"
              },
              {
                "in": "query",
                "name": "after",
