{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "threads",
      "commands": [
        {
          "name": "messages",
          "commands": [
            {
              "name": "create",
              "description": "Create a message.",
              "arguments": [
                {
                  "name": "thread-id",
                  "required": true,
                  "description": "The ID of the [thread](/docs/api-reference/threads) to create a message for."
                }
              ],
              "options": [
                {
                  "name": "role",
                  "group": "body",
                  "required": true,
                  "description": "The role of the entity that is creating the message. Allowed values include:\n- `user`: Indicates the message is sent by an actual user and should be used in most cases to represent user-generated messages.\n- `assistant`: Indicates the message is generated by the assistant. Use this value to insert messages from the assistant into the conversation.\n",
                  "arguments": [
                    {
                      "name": "string",
                      "acceptedValues": [
                        "user",
                        "assistant"
                      ]
                    }
                  ]
                },
                {
                  "name": "content",
                  "group": "body",
                  "required": true,
                  "arguments": [
                    {
                      "name": "value"
                    }
                  ]
                },
                {
                  "name": "attachments",
                  "group": "body",
                  "arguments": [
                    {
                      "name": "value"
                    }
                  ]
                },
                {
                  "name": "metadata",
                  "group": "body",
                  "arguments": [
                    {
                      "name": "value"
                    }
                  ]
                }
              ],
              "x-openapi": {
                "method": "post",
                "path": "/threads/{thread_id}/messages",
                "operationId": "createMessage",
                "contentType": "application/json",
                "params": [
                  {
                    "in": "path",
                    "name": "thread_id",
                    "from": "argument:thread-id",
                    "required": true
                  }
                ],
                "body": {
                  "style": "flatten",
                  "contentType": "application/json",
                  "properties": [
                    {
                      "name": "role",
                      "from": "option:role",
                      "jsonPath": "role",
                      "encoding": "string",
                      "required": true
                    },
                    {
                      "name": "content",
                      "from": "option:content",
                      "jsonPath": "content",
                      "encoding": "json",
                      "required": true
                    },
                    {
                      "name": "attachments",
                      "from": "option:attachments",
                      "jsonPath": "attachments",
                      "encoding": "json"
                    },
                    {
                      "name": "metadata",
                      "from": "option:metadata",
                      "jsonPath": "metadata",
                      "encoding": "json"
                    }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
