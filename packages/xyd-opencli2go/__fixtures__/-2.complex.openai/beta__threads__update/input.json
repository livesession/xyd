{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "threads",
      "commands": [
        {
          "name": "create",
          "description": "Create a thread.",
          "options": [
            {
              "name": "messages",
              "group": "body",
              "description": "A list of [messages](/docs/api-reference/messages) to start the thread with.",
              "arguments": [
                {
                  "name": "json",
                  "arity": {
                    "minimum": 0
                  }
                }
              ]
            },
            {
              "name": "tool-resources",
              "group": "body",
              "arguments": [
                {
                  "name": "value"
                }
              ]
            },
            {
              "name": "metadata",
              "group": "body",
              "arguments": [
                {
                  "name": "value"
                }
              ]
            }
          ],
          "x-openapi": {
            "method": "post",
            "path": "/threads",
            "operationId": "createThread",
            "contentType": "application/json",
            "body": {
              "style": "flatten",
              "contentType": "application/json",
              "properties": [
                {
                  "name": "messages",
                  "from": "option:messages",
                  "jsonPath": "messages",
                  "encoding": "array"
                },
                {
                  "name": "tool_resources",
                  "from": "option:tool-resources",
                  "jsonPath": "tool_resources",
                  "encoding": "json"
                },
                {
                  "name": "metadata",
                  "from": "option:metadata",
                  "jsonPath": "metadata",
                  "encoding": "json"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
