{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "vector-stores",
      "commands": [
        {
          "name": "files",
          "commands": [
            {
              "name": "delete",
              "description": "Delete a vector store file. This will remove the file from the vector store but the file itself will not be deleted. To delete the file, use the [delete file](/docs/api-reference/files/delete) endpoint.",
              "arguments": [
                {
                  "name": "vector-store-id",
                  "required": true,
                  "description": "The ID of the vector store that the file belongs to."
                },
                {
                  "name": "file-id",
                  "required": true,
                  "description": "The ID of the file to delete."
                }
              ],
              "x-openapi": {
                "method": "delete",
                "path": "/vector_stores/{vector_store_id}/files/{file_id}",
                "operationId": "deleteVectorStoreFile",
                "params": [
                  {
                    "in": "path",
                    "name": "vector_store_id",
                    "from": "argument:vector-store-id",
                    "required": true
                  },
                  {
                    "in": "path",
                    "name": "file_id",
                    "from": "argument:file-id",
                    "required": true
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
