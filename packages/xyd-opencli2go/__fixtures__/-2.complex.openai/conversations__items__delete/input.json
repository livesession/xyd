{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "conversations",
      "commands": [
        {
          "name": "items",
          "commands": [
            {
              "name": "delete",
              "description": "Delete an item from a conversation with the given IDs.",
              "arguments": [
                {
                  "name": "conversation-id",
                  "required": true,
                  "description": "The ID of the conversation that contains the item."
                },
                {
                  "name": "item-id",
                  "required": true,
                  "description": "The ID of the item to delete."
                }
              ],
              "x-openapi": {
                "method": "delete",
                "path": "/conversations/{conversation_id}/items/{item_id}",
                "operationId": "deleteConversationItem",
                "params": [
                  {
                    "in": "path",
                    "name": "conversation_id",
                    "from": "argument:conversation-id",
                    "required": true
                  },
                  {
                    "in": "path",
                    "name": "item_id",
                    "from": "argument:item-id",
                    "required": true
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
