{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "audio",
      "commands": [
        {
          "name": "speech",
          "commands": [
            {
              "name": "create",
              "description": "Generates audio from the input text.\n\nReturns the audio file content, or a stream of audio events.\n",
              "options": [
                {
                  "name": "model",
                  "group": "body",
                  "required": true,
                  "description": "One of the available [TTS models](/docs/models#tts): `tts-1`, `tts-1-hd`, `gpt-4o-mini-tts`, or `gpt-4o-mini-tts-2025-12-15`.\n",
                  "arguments": [
                    {
                      "name": "value"
                    }
                  ]
                },
                {
                  "name": "input",
                  "group": "body",
                  "required": true,
                  "description": "The text to generate audio for. The maximum length is 4096 characters.",
                  "arguments": [
                    {
                      "name": "string"
                    }
                  ]
                },
                {
                  "name": "instructions",
                  "group": "body",
                  "description": "Control the voice of your generated audio with additional instructions. Does not work with `tts-1` or `tts-1-hd`.",
                  "arguments": [
                    {
                      "name": "string"
                    }
                  ]
                },
                {
                  "name": "voice",
                  "group": "body",
                  "required": true,
                  "description": "The voice to use when generating the audio. Supported built-in voices are `alloy`, `ash`, `ballad`, `coral`, `echo`, `fable`, `onyx`, `nova`, `sage`, `shimmer`, `verse`, `marin`, and `cedar`. You may also provide a custom voice object with an `id`, for example `{ \"id\": \"voice_1234\" }`. Previews of the voices are available in the [Text to speech guide](/docs/guides/text-to-speech#voice-options).",
                  "arguments": [
                    {
                      "name": "value"
                    }
                  ]
                },
                {
                  "name": "response-format",
                  "group": "body",
                  "description": "The format to audio in. Supported formats are `mp3`, `opus`, `aac`, `flac`, `wav`, and `pcm`.",
                  "arguments": [
                    {
                      "name": "string",
                      "acceptedValues": [
                        "mp3",
                        "opus",
                        "aac",
                        "flac",
                        "wav",
                        "pcm"
                      ]
                    }
                  ]
                },
                {
                  "name": "speed",
                  "group": "body",
                  "description": "The speed of the generated audio. Select a value from `0.25` to `4.0`. `1.0` is the default.",
                  "arguments": [
                    {
                      "name": "number"
                    }
                  ]
                },
                {
                  "name": "stream-format",
                  "group": "body",
                  "description": "The format to stream the audio in. Supported formats are `sse` and `audio`. `sse` is not supported for `tts-1` or `tts-1-hd`.",
                  "arguments": [
                    {
                      "name": "string",
                      "acceptedValues": [
                        "sse",
                        "audio"
                      ]
                    }
                  ]
                }
              ],
              "x-openapi": {
                "method": "post",
                "path": "/audio/speech",
                "operationId": "createSpeech",
                "contentType": "application/json",
                "body": {
                  "style": "flatten",
                  "contentType": "application/json",
                  "properties": [
                    {
                      "name": "model",
                      "from": "option:model",
                      "jsonPath": "model",
                      "encoding": "json",
                      "required": true
                    },
                    {
                      "name": "input",
                      "from": "option:input",
                      "jsonPath": "input",
                      "encoding": "string",
                      "required": true
                    },
                    {
                      "name": "instructions",
                      "from": "option:instructions",
                      "jsonPath": "instructions",
                      "encoding": "string"
                    },
                    {
                      "name": "voice",
                      "from": "option:voice",
                      "jsonPath": "voice",
                      "encoding": "json",
                      "required": true
                    },
                    {
                      "name": "response_format",
                      "from": "option:response-format",
                      "jsonPath": "response_format",
                      "encoding": "string"
                    },
                    {
                      "name": "speed",
                      "from": "option:speed",
                      "jsonPath": "speed",
                      "encoding": "number"
                    },
                    {
                      "name": "stream_format",
                      "from": "option:stream-format",
                      "jsonPath": "stream_format",
                      "encoding": "string"
                    }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
