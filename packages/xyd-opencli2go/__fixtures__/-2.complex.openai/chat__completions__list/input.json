{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "chat",
      "commands": [
        {
          "name": "completions",
          "commands": [
            {
              "name": "list",
              "description": "List stored Chat Completions. Only Chat Completions that have been stored\nwith the `store` parameter set to `true` will be returned.\n",
              "options": [
                {
                  "name": "model",
                  "description": "The model used to generate the Chat Completions.",
                  "group": "query",
                  "arguments": [
                    {
                      "name": "string"
                    }
                  ]
                },
                {
                  "name": "metadata",
                  "description": "A list of metadata keys to filter the Chat Completions by. Example:\n\n`metadata[key1]=value1&metadata[key2]=value2`\n",
                  "group": "query",
                  "arguments": [
                    {
                      "name": "value"
                    }
                  ]
                },
                {
                  "name": "after",
                  "description": "Identifier for the last chat completion from the previous pagination request.",
                  "group": "query",
                  "arguments": [
                    {
                      "name": "string"
                    }
                  ]
                },
                {
                  "name": "limit",
                  "description": "Number of Chat Completions to retrieve.",
                  "group": "query",
                  "arguments": [
                    {
                      "name": "integer"
                    }
                  ]
                },
                {
                  "name": "order",
                  "description": "Sort order for Chat Completions by timestamp. Use `asc` for ascending order or `desc` for descending order. Defaults to `asc`.",
                  "group": "query",
                  "arguments": [
                    {
                      "name": "string",
                      "acceptedValues": [
                        "asc",
                        "desc"
                      ]
                    }
                  ]
                }
              ],
              "x-openapi": {
                "method": "get",
                "path": "/chat/completions",
                "operationId": "listChatCompletions",
                "params": [
                  {
                    "in": "query",
                    "name": "model",
                    "from": "option:model"
                  },
                  {
                    "in": "query",
                    "name": "metadata",
                    "from": "option:metadata"
                  },
                  {
                    "in": "query",
                    "name": "after",
                    "from": "option:after"
                  },
                  {
                    "in": "query",
                    "name": "limit",
                    "from": "option:limit"
                  },
                  {
                    "in": "query",
                    "name": "order",
                    "from": "option:order"
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
