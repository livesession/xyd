{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "skills",
      "commands": [
        {
          "name": "versions",
          "commands": [
            {
              "name": "delete",
              "description": "Delete a skill version.",
              "arguments": [
                {
                  "name": "skill-id",
                  "required": true,
                  "description": "The identifier of the skill."
                },
                {
                  "name": "version",
                  "required": true,
                  "description": "The skill version number."
                }
              ],
              "x-openapi": {
                "method": "delete",
                "path": "/skills/{skill_id}/versions/{version}",
                "operationId": "DeleteSkillVersion",
                "params": [
                  {
                    "in": "path",
                    "name": "skill_id",
                    "from": "argument:skill-id",
                    "required": true
                  },
                  {
                    "in": "path",
                    "name": "version",
                    "from": "argument:version",
                    "required": true
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
