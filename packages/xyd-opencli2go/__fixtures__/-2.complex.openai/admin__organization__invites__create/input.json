{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "organization",
      "commands": [
        {
          "name": "invites",
          "commands": [
            {
              "name": "create",
              "description": "Create an invite for a user to the organization. The invite must be accepted by the user before they have access to the organization.",
              "options": [
                {
                  "name": "email",
                  "group": "body",
                  "required": true,
                  "description": "Send an email to this address",
                  "arguments": [
                    {
                      "name": "string"
                    }
                  ]
                },
                {
                  "name": "role",
                  "group": "body",
                  "required": true,
                  "description": "`owner` or `reader`",
                  "arguments": [
                    {
                      "name": "string",
                      "acceptedValues": [
                        "reader",
                        "owner"
                      ]
                    }
                  ]
                },
                {
                  "name": "projects",
                  "group": "body",
                  "description": "An array of projects to which membership is granted at the same time the org invite is accepted. If omitted, the user will be invited to the default project for compatibility with legacy behavior.",
                  "arguments": [
                    {
                      "name": "json",
                      "arity": {
                        "minimum": 0
                      }
                    }
                  ]
                }
              ],
              "x-openapi": {
                "method": "post",
                "path": "/organization/invites",
                "operationId": "inviteUser",
                "contentType": "application/json",
                "body": {
                  "style": "flatten",
                  "contentType": "application/json",
                  "properties": [
                    {
                      "name": "email",
                      "from": "option:email",
                      "jsonPath": "email",
                      "encoding": "string",
                      "required": true
                    },
                    {
                      "name": "role",
                      "from": "option:role",
                      "jsonPath": "role",
                      "encoding": "string",
                      "required": true
                    },
                    {
                      "name": "projects",
                      "from": "option:projects",
                      "jsonPath": "projects",
                      "encoding": "array"
                    }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
