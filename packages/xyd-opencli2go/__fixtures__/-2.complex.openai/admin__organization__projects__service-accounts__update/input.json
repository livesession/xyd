{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "organization",
      "commands": [
        {
          "name": "projects",
          "commands": [
            {
              "name": "service-accounts",
              "commands": [
                {
                  "name": "create",
                  "description": "Creates a new service account in the project. This also returns an unredacted API key for the service account.",
                  "arguments": [
                    {
                      "name": "project-id",
                      "required": true,
                      "description": "The ID of the project."
                    }
                  ],
                  "options": [
                    {
                      "name": "name",
                      "group": "body",
                      "required": true,
                      "description": "The name of the service account being created.",
                      "arguments": [
                        {
                          "name": "string"
                        }
                      ]
                    }
                  ],
                  "x-openapi": {
                    "method": "post",
                    "path": "/organization/projects/{project_id}/service_accounts",
                    "operationId": "create-project-service-account",
                    "contentType": "application/json",
                    "params": [
                      {
                        "in": "path",
                        "name": "project_id",
                        "from": "argument:project-id",
                        "required": true
                      }
                    ],
                    "body": {
                      "style": "flatten",
                      "contentType": "application/json",
                      "properties": [
                        {
                          "name": "name",
                          "from": "option:name",
                          "jsonPath": "name",
                          "encoding": "string",
                          "required": true
                        }
                      ]
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
