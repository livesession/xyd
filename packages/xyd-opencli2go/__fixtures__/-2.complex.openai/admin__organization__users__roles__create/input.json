  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "organization",
      "commands": [
        {
          "name": "users",
          "commands": [
            {
              "name": "roles",
              "commands": [
                {
                  "name": "create",
                  "description": "Assigns an organization role to a user within the organization.",
                  "arguments": [
                    {
                      "name": "user-id",
                      "required": true,
                      "description": "The ID of the user that should receive the organization role."
                    }
                  ],
                  "options": [
                    {
                      "name": "role-id",
                      "group": "body",
                      "required": true,
                      "description": "Identifier of the role to assign.",
                      "arguments": [
                        {
                          "name": "string"
                        }
                      ]
                    }
                  ],
                  "x-openapi": {
                    "method": "post",
                    "path": "/organization/users/{user_id}/roles",
                    "operationId": "assign-user-role",
                    "contentType": "application/json",
                    "params": [
                      {
                        "in": "path",
                        "name": "user_id",
                        "from": "argument:user-id",
                        "required": true
                      }
                    ],
                    "body": {
                      "style": "flatten",
                      "contentType": "application/json",
                      "properties": [
                        {
                          "name": "role_id",
                          "from": "option:role-id",
                          "jsonPath": "role_id",
                          "encoding": "string",
                          "required": true
                        }
                      ]
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
