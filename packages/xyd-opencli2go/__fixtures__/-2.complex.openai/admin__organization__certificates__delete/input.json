{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "organization",
      "commands": [
        {
          "name": "certificates",
          "commands": [
            {
              "name": "delete",
              "description": "Delete a certificate from the organization.\n\nThe certificate must be inactive for the organization and all projects.\n",
              "arguments": [
                {
                  "name": "certificate-id",
                  "required": true,
                  "description": "Unique ID of the certificate to delete."
                }
              ],
              "x-openapi": {
                "method": "delete",
                "path": "/organization/certificates/{certificate_id}",
                "operationId": "deleteCertificate",
                "params": [
                  {
                    "in": "path",
                    "name": "certificate_id",
                    "from": "argument:certificate-id",
                    "required": true
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
