                  "description": "Human readable name for the group.",
                  "arguments": [
                    {
                      "name": "string"
                    }
                  ]
                }
              ],
              "x-openapi": {
                "method": "post",
                "path": "/organization/groups",
                "operationId": "create-group",
                "contentType": "application/json",
                "body": {
                  "style": "flatten",
                  "contentType": "application/json",
                  "properties": [
                    {
                      "name": "name",
                      "from": "option:name",
                      "jsonPath": "name",
                      "encoding": "string",
                      "required": true
                    }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
