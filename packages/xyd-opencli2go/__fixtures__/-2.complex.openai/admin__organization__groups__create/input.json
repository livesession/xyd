{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "organization",
      "commands": [
        {
          "name": "groups",
