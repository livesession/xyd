{
  "opencli": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "x-openapi": {
    "servers": [
      "https://api.openai.com/v1"
    ],
    "security": [
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      },
      {
        "type": "http",
        "kind": "bearer",
        "envVar": "OPENAI_API_KEY",
        "scheme": "bearer"
      }
    ]
  },
  "commands": [
    {
      "name": "organization",
      "commands": [
        {
          "name": "groups",
          "commands": [
            {
              "name": "roles",
              "commands": [
                {
                  "name": "delete",
                  "description": "Unassigns an organization role from a group within the organization.",
                  "arguments": [
                    {
                      "name": "group-id",
                      "required": true,
                      "description": "The ID of the group to modify."
                    },
                    {
                      "name": "role-id",
                      "required": true,
                      "description": "The ID of the organization role to remove from the group."
                    }
                  ],
                  "x-openapi": {
                    "method": "delete",
                    "path": "/organization/groups/{group_id}/roles/{role_id}",
                    "operationId": "unassign-group-role",
                    "params": [
                      {
                        "in": "path",
                        "name": "group_id",
                        "from": "argument:group-id",
                        "required": true
                      },
                      {
                        "in": "path",
                        "name": "role_id",
                        "from": "argument:role-id",
                        "required": true
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
