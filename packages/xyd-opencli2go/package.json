{
  "name": "@xyd-js/opencli2go",
  "version": "0.1.0-build.0",
  "description": "Generate a buildable Go CLI (urfave/cli v3) from an OpenCLI document with the x-openapi request binding",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run",
    "format": "bunx biome check --write src"
  },
  "dependencies": {
    "@xyd-js/opencli": "workspace:*"
  },
  "devDependencies": {
    "@xyd-js/openapi": "workspace:*",
    "@xyd-js/openapi2opencli": "workspace:*",
    "@types/node": "^20.9.0",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
