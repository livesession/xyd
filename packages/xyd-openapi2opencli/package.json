{
  "name": "@xyd-js/openapi2opencli",
  "version": "0.1.0-build.0",
  "description": "Convert an OpenAPI 3.x document into an OpenCLI document (with the x-openapi request binding) consumable by the opencli2* code generators",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run",
    "format": "bunx biome check --write src"
  },
  "dependencies": {
    "@xyd-js/opencli": "workspace:*",
    "@xyd-js/openapi": "workspace:*",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
