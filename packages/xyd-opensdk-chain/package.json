{
  "name": "@xyd-js/opensdk-chain",
  "version": "0.1.0-build.0",
  "description": "OpenSDK chain pipeline (a Speakeasy workflow.yaml analog): process OpenAPI sources (merge inputs + apply overlays) and run many targets from one chain.json — the `opensdk run` engine.",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
    "test": "vitest",
    "ci:test": "vitest run",
    "format": "bunx biome check --write src index.ts"
  },
  "dependencies": {
    "@xyd-js/opensdk-core": "workspace:*",
    "@xyd-js/opensdk-framework": "workspace:*",
    "js-yaml": "^4.1.0",
    "jsonpath-plus": "^10.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.9.0",
    "@xyd-js/openapi2opensdk": "workspace:*",
    "@xyd-js/opensdk-ci": "workspace:*",
    "@xyd-js/opensdk-go": "workspace:*",
    "@xyd-js/opensdk-python": "workspace:*",
    "@xyd-js/opensdk-node": "workspace:*",
    "@xyd-js/opensdk-ruby": "workspace:*",
    "@xyd-js/opensdk-java": "workspace:*",
    "@xyd-js/opensdk-dotnet": "workspace:*",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
