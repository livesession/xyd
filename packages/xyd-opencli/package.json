    "format": "bunx biome check --write src"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.9.0",
    "json-schema-to-typescript": "^14.0.1",
    "rimraf": "^3.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
