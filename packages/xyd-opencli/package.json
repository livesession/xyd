{
  "name": "@xyd-js/opencli",
  "version": "0.1.0-build.0",
  "description": "OpenCLI core model and helpers (shared by opencli-remark and the openapi2opencli / opencli2* generators)",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsup",
