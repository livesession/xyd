{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "ProjectCreateRequest",
      "kind": "struct",
      "fields": [
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The friendly name of the project, this name appears in reports."
        },
        {
          "name": "geography",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": false,
          "description": "Create the project with the specified data residency region. Your organization must have access to Data residency functionality in order to use. See [data residency controls](/docs/guides/your-data#data-residency-controls) to review the functionality and limitations of setting this field."
        },
        {
          "name": "external_key_id",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": false,
          "description": "External key ID to associate with the project."
        }
      ]
    },
    {
      "name": "Project",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The identifier, which can be referenced in API endpoints"
        },
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "organization.project"
          },
          "required": true,
          "description": "The object type, which is always `organization.project`"
        },
        {
          "name": "name",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": false,
          "description": "The name of the project. This appears in reporting."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "The Unix timestamp (in seconds) of when the project was created."
        },
        {
          "name": "archived_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime",
            "nullable": true
          },
          "required": false
        },
        {
          "name": "status",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": false,
          "description": "`active` or `archived`"
        },
        {
          "name": "external_key_id",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "nullable": true
          },
          "required": false,
          "description": "The external key associated with the project."
        }
      ],
      "description": "Represents an individual project."
    }
  ],
  "resources": [
    {
      "name": "admin",
      "resources": [
        {
          "name": "organization",
          "resources": [
            {
              "name": "projects",
              "methods": [
                {
                  "action": "create",
                  "httpMethod": "post",
                  "path": "/organization/projects",
                  "operationId": "create-project",
                  "description": "Create a new project in the organization. Projects can be created and archived, but cannot be deleted.",
                  "requestBody": {
                    "contentType": "application/json",
                    "type": {
                      "kind": "ref",
                      "name": "ProjectCreateRequest"
                    },
                    "required": true,
                    "encoding": "json",
                    "description": "The project create request payload."
                  },
                  "responses": [
                    {
                      "status": "200",
                      "description": "Project created successfully.",
                      "contentType": "application/json",
                      "type": {
                        "kind": "ref",
                        "name": "Project"
                      }
                    }
                  ],
                  "primaryResponse": {
                    "kind": "ref",
                    "name": "Project"
                  },
                  "security": [
                    {
                      "type": "http",
                      "kind": "bearer",
                      "schemeName": "AdminApiKeyAuth",
                      "scheme": "bearer"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
      "maxRetries": 2,
      "retryableStatusCodes": [
        408,
        429,
        500,
        502,
        503,
        504
      ],
      "retryConnectionErrors": true,
      "honorRetryAfterHeader": true,
      "backoff": {
        "initialDelayMs": 500,
        "maxDelayMs": 8000,
        "multiplier": 2,
        "jitter": 0.25
      }
    },
    "timeout": {
      "defaultTimeoutMs": 60000
    },
    "errors": {
      "statusCodeMap": {
        "400": "BadRequest",
        "401": "Unauthorized",
        "403": "PermissionDenied",
        "404": "NotFound",
        "409": "Conflict",
        "422": "UnprocessableEntity",
        "429": "RateLimited"
      },
      "clientErrorKind": "API",
      "serverErrorKind": "Internal"
    },
    "userAgent": {
      "sdkIdentifierTemplate": "{package}-{language}/{version}",
      "includeRuntimeVersion": false,
      "aiAgentEnvVars": {
        "CLAUDE_CODE": "claude-code",
        "CURSOR_AGENT": "cursor",
        "CLINE_ACTIVE": "cline",
        "WINDSURF_ACTIVE": "windsurf",
        "COPILOT_AGENT": "copilot"
      }
    },
    "telemetry": {
      "requestIdHeader": "X-Request-ID",
      "headerName": "X-Client-Telemetry",
      "enabledByDefault": false
    },
    "logging": {
      "events": [
        "request.start",
        "request.success",
        "request.retry",
        "request.rate_limited",
        "request.error",
        "request.connection_error"
      ]
    },
    "idempotency": {
      "headerName": "Idempotency-Key",
      "autoGenerateForPost": true
    },
    "pagination": {
      "autoPageDelayMs": 0
    },
    "requestGuard": {
      "optionKeys": [
        "api_key",
        "apiKey",
        "idempotency_key",
        "idempotencyKey",
        "extra_headers",
        "extraHeaders",
        "max_retries",
        "maxRetries",
        "base_url",
        "baseUrl",
        "timeout"
      ]
    }
  }
}
