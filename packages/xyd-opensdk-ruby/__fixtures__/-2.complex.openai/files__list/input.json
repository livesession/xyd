{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "FilesListOrder",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "asc"
        },
        {
          "value": "desc"
        }
      ]
    },
    {
      "name": "ListFilesResponse",
      "kind": "struct",
      "fields": [
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true
        },
        {
          "name": "data",
          "type": {
            "kind": "array",
            "items": {
              "kind": "ref",
              "name": "OpenAiFile"
            }
          },
          "required": true
        },
        {
          "name": "first_id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true
        },
        {
          "name": "last_id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true
        },
        {
          "name": "has_more",
          "type": {
            "kind": "scalar",
            "scalar": "boolean"
          },
          "required": true
        }
      ]
    },
    {
      "name": "OpenAiFile",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The file identifier, which can be referenced in the API endpoints."
        },
        {
          "name": "bytes",
          "type": {
            "kind": "scalar",
            "scalar": "integer"
          },
          "required": true,
          "description": "The size of the file, in bytes."
        },
        {
          "name": "created_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": true,
          "description": "The Unix timestamp (in seconds) for when the file was created."
        },
        {
          "name": "expires_at",
          "type": {
            "kind": "scalar",
            "scalar": "integer",
            "format": "unixtime"
          },
          "required": false,
          "description": "The Unix timestamp (in seconds) for when the file will expire."
        },
        {
          "name": "filename",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The name of the file."
        },
        {
          "name": "object",
          "type": {
            "kind": "scalar",
            "scalar": "string",
            "const": "file"
          },
          "required": true,
          "description": "The object type, which is always `file`."
        },
        {
          "name": "purpose",
          "type": {
            "kind": "ref",
            "name": "OpenAiFilePurpose"
          },
          "required": true,
          "description": "The intended purpose of the file. Supported values are `assistants`, `assistants_output`, `batch`, `batch_output`, `fine-tune`, `fine-tune-results`, `vision`, and `user_data`."
        },
        {
          "name": "status",
          "type": {
            "kind": "ref",
            "name": "OpenAiFileStatus"
          },
          "required": true,
          "deprecated": true,
          "description": "Deprecated. The current status of the file, which can be either `uploaded`, `processed`, or `error`."
        },
        {
          "name": "status_details",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": false,
          "deprecated": true,
          "description": "Deprecated. For details on why a fine-tuning training file failed validation, see the `error` field on `fine_tuning.job`."
        }
      ],
      "description": "The `File` object represents a document that has been uploaded to OpenAI."
    },
    {
      "name": "OpenAiFilePurpose",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "assistants"
        },
        {
          "value": "assistants_output"
        },
        {
          "value": "batch"
        },
        {
          "value": "batch_output"
        },
        {
          "value": "fine-tune"
        },
        {
          "value": "fine-tune-results"
        },
        {
          "value": "vision"
        },
        {
          "value": "user_data"
        }
      ],
      "description": "The intended purpose of the file. Supported values are `assistants`, `assistants_output`, `batch`, `batch_output`, `fine-tune`, `fine-tune-results`, `vision`, and `user_data`."
    },
    {
      "name": "OpenAiFileStatus",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "uploaded"
        },
        {
          "value": "processed"
        },
        {
          "value": "error"
        }
      ],
      "description": "Deprecated. The current status of the file, which can be either `uploaded`, `processed`, or `error`."
    }
  ],
  "resources": [
    {
      "name": "files",
      "methods": [
        {
          "action": "list",
          "httpMethod": "get",
          "path": "/files",
          "operationId": "listFiles",
          "description": "Returns a list of files.",
          "queryParams": [
            {
              "name": "purpose",
              "type": {
                "kind": "scalar",
                "scalar": "string"
              },
              "required": false,
              "description": "Only return files with the given purpose."
            },
            {
              "name": "limit",
              "type": {
                "kind": "scalar",
                "scalar": "integer"
              },
              "required": false,
              "description": "A limit on the number of objects to be returned. Limit can range between 1 and 10,000, and the default is 10,000.\n",
              "default": 10000
            },
            {
              "name": "order",
              "type": {
                "kind": "ref",
                "name": "FilesListOrder"
              },
              "required": false,
              "description": "Sort order by the `created_at` timestamp of the objects. `asc` for ascending order and `desc` for descending order.\n",
              "default": "desc"
            },
            {
              "name": "after",
              "type": {
                "kind": "scalar",
                "scalar": "string"
              },
              "required": false,
              "description": "A cursor for use in pagination. `after` is an object ID that defines your place in the list. For instance, if you make a list request and receive 100 objects, ending with obj_foo, your subsequent call can include after=obj_foo in order to fetch the next page of the list.\n"
            }
          ],
          "responses": [
            {
              "status": "200",
              "description": "OK",
              "contentType": "application/json",
              "type": {
                "kind": "ref",
                "name": "ListFilesResponse"
              }
            }
          ],
          "primaryResponse": {
            "kind": "ref",
            "name": "ListFilesResponse"
          },
          "pagination": {
            "style": "cursor",
            "itemsField": "data",
            "nextField": "has_more",
            "itemType": {
              "kind": "ref",
              "name": "OpenAiFile"
            },
            "cursorParam": "after",
            "limitParam": "limit"
          }
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
