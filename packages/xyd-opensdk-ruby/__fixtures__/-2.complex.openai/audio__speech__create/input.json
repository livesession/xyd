{
  "opensdk": "1.0.0",
  "info": {
    "title": "openai",
    "version": "2.3.0"
  },
  "servers": [
    "https://api.openai.com/v1"
  ],
  "security": [
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "ApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    },
    {
      "type": "http",
      "kind": "bearer",
      "schemeName": "AdminApiKeyAuth",
      "envVar": "OPENAI_API_KEY",
      "scheme": "bearer"
    }
  ],
  "types": [
    {
      "name": "CreateSpeechRequest",
      "kind": "struct",
      "fields": [
        {
          "name": "model",
          "type": {
            "kind": "ref",
            "name": "CreateSpeechRequestModel"
          },
          "required": true,
          "description": "One of the available [TTS models](/docs/models#tts): `tts-1`, `tts-1-hd`, `gpt-4o-mini-tts`, or `gpt-4o-mini-tts-2025-12-15`.\n"
        },
        {
          "name": "input",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The text to generate audio for. The maximum length is 4096 characters."
        },
        {
          "name": "instructions",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": false,
          "description": "Control the voice of your generated audio with additional instructions. Does not work with `tts-1` or `tts-1-hd`."
        },
        {
          "name": "voice",
          "type": {
            "kind": "ref",
            "name": "VoiceIdsOrCustomVoice"
          },
          "required": true
        },
        {
          "name": "response_format",
          "type": {
            "kind": "ref",
            "name": "CreateSpeechRequestResponseFormat"
          },
          "required": false,
          "default": "mp3",
          "description": "The format to audio in. Supported formats are `mp3`, `opus`, `aac`, `flac`, `wav`, and `pcm`."
        },
        {
          "name": "speed",
          "type": {
            "kind": "scalar",
            "scalar": "number"
          },
          "required": false,
          "default": 1,
          "description": "The speed of the generated audio. Select a value from `0.25` to `4.0`. `1.0` is the default."
        },
        {
          "name": "stream_format",
          "type": {
            "kind": "ref",
            "name": "CreateSpeechRequestStreamFormat"
          },
          "required": false,
          "default": "audio",
          "description": "The format to stream the audio in. Supported formats are `sse` and `audio`. `sse` is not supported for `tts-1` or `tts-1-hd`."
        }
      ]
    },
    {
      "name": "CreateSpeechRequestModel",
      "kind": "union",
      "semantics": "anyOf",
      "variants": [
        {
          "kind": "scalar",
          "scalar": "string"
        },
        {
          "kind": "ref",
          "name": "CreateSpeechRequestModelString"
        }
      ],
      "description": "One of the available [TTS models](/docs/models#tts): `tts-1`, `tts-1-hd`, `gpt-4o-mini-tts`, or `gpt-4o-mini-tts-2025-12-15`.\n"
    },
    {
      "name": "CreateSpeechRequestModelString",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "tts-1"
        },
        {
          "value": "tts-1-hd"
        },
        {
          "value": "gpt-4o-mini-tts"
        },
        {
          "value": "gpt-4o-mini-tts-2025-12-15"
        }
      ]
    },
    {
      "name": "VoiceIdsOrCustomVoice",
      "kind": "union",
      "semantics": "anyOf",
      "variants": [
        {
          "kind": "ref",
          "name": "VoiceIdsShared"
        },
        {
          "kind": "ref",
          "name": "VoiceIdsOrCustomVoiceVariant1"
        }
      ],
      "description": "A built-in voice name or a custom voice reference.\n"
    },
    {
      "name": "VoiceIdsShared",
      "kind": "union",
      "semantics": "anyOf",
      "variants": [
        {
          "kind": "scalar",
          "scalar": "string"
        },
        {
          "kind": "ref",
          "name": "VoiceIdsSharedString"
        }
      ]
    },
    {
      "name": "VoiceIdsSharedString",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "alloy"
        },
        {
          "value": "ash"
        },
        {
          "value": "ballad"
        },
        {
          "value": "coral"
        },
        {
          "value": "echo"
        },
        {
          "value": "sage"
        },
        {
          "value": "shimmer"
        },
        {
          "value": "verse"
        },
        {
          "value": "marin"
        },
        {
          "value": "cedar"
        }
      ]
    },
    {
      "name": "VoiceIdsOrCustomVoiceVariant1",
      "kind": "struct",
      "fields": [
        {
          "name": "id",
          "type": {
            "kind": "scalar",
            "scalar": "string"
          },
          "required": true,
          "description": "The custom voice ID, e.g. `voice_1234`."
        }
      ],
      "description": "Custom voice reference."
    },
    {
      "name": "CreateSpeechRequestResponseFormat",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "mp3"
        },
        {
          "value": "opus"
        },
        {
          "value": "aac"
        },
        {
          "value": "flac"
        },
        {
          "value": "wav"
        },
        {
          "value": "pcm"
        }
      ],
      "description": "The format to audio in. Supported formats are `mp3`, `opus`, `aac`, `flac`, `wav`, and `pcm`."
    },
    {
      "name": "CreateSpeechRequestStreamFormat",
      "kind": "enum",
      "base": "string",
      "values": [
        {
          "value": "sse"
        },
        {
          "value": "audio"
        }
      ],
      "description": "The format to stream the audio in. Supported formats are `sse` and `audio`. `sse` is not supported for `tts-1` or `tts-1-hd`."
    }
  ],
  "resources": [
    {
      "name": "audio",
      "resources": [
        {
          "name": "speech",
          "methods": [
            {
              "action": "create",
              "httpMethod": "post",
              "path": "/audio/speech",
              "operationId": "createSpeech",
              "description": "Generates audio from the input text.\n\nReturns the audio file content, or a stream of audio events.\n",
              "requestBody": {
                "contentType": "application/json",
                "type": {
                  "kind": "ref",
                  "name": "CreateSpeechRequest"
                },
                "required": true,
                "encoding": "json"
              },
              "responses": [
                {
                  "status": "200",
                  "description": "OK",
                  "contentType": "application/octet-stream",
                  "type": {
                    "kind": "scalar",
                    "scalar": "string",
                    "format": "binary"
                  }
                }
              ],
              "primaryResponse": {
                "kind": "scalar",
                "scalar": "string",
                "format": "binary"
              }
            }
          ]
        }
      ]
    }
  ],
  "sdk": {
    "retry": {
      "maxRetries": 2,
      "retryableStatusCodes": [
        408,
        429,
        500,
        502,
        503,
        504
      ],
      "retryConnectionErrors": true,
      "honorRetryAfterHeader": true,
      "backoff": {
        "initialDelayMs": 500,
        "maxDelayMs": 8000,
        "multiplier": 2,
        "jitter": 0.25
      }
    },
    "timeout": {
      "defaultTimeoutMs": 60000
    },
    "errors": {
      "statusCodeMap": {
        "400": "BadRequest",
        "401": "Unauthorized",
        "403": "PermissionDenied",
        "404": "NotFound",
        "409": "Conflict",
        "422": "UnprocessableEntity",
        "429": "RateLimited"
      },
      "clientErrorKind": "API",
      "serverErrorKind": "Internal"
    },
    "userAgent": {
      "sdkIdentifierTemplate": "{package}-{language}/{version}",
      "includeRuntimeVersion": false,
      "aiAgentEnvVars": {
        "CLAUDE_CODE": "claude-code",
        "CURSOR_AGENT": "cursor",
        "CLINE_ACTIVE": "cline",
        "WINDSURF_ACTIVE": "windsurf",
        "COPILOT_AGENT": "copilot"
      }
    },
    "telemetry": {
      "requestIdHeader": "X-Request-ID",
      "headerName": "X-Client-Telemetry",
      "enabledByDefault": false
    },
    "logging": {
      "events": [
        "request.start",
        "request.success",
        "request.retry",
        "request.rate_limited",
        "request.error",
        "request.connection_error"
      ]
    },
    "idempotency": {
      "headerName": "Idempotency-Key",
      "autoGenerateForPost": true
    },
    "pagination": {
      "autoPageDelayMs": 0
    },
    "requestGuard": {
      "optionKeys": [
        "api_key",
        "apiKey",
        "idempotency_key",
        "idempotencyKey",
        "extra_headers",
        "extraHeaders",
        "max_retries",
        "maxRetries",
        "base_url",
        "baseUrl",
        "timeout"
      ]
    }
  }
}
